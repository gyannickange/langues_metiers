<%# app/views/diagnostics/_likert_question.html.erb %>
<%# Locals: question (DiagnosticQuestion), index (Integer), current_value (String, optional) %>
<fieldset class="diagnostic-motion-item bg-white rounded-2xl border border-slate-200 p-5 sm:p-6 shadow-sm"
          style="--motion-index: <%= [index, 5].min %>">
  <legend class="w-full font-semibold text-slate-700 mb-5">
    <span class="text-[var(--color-primary)] mr-2"><%= index + 1 %>.</span>
    <%= question.text %>
  </legend>
  <div class="flex gap-2 justify-between">
    <% (1..5).each do |value| %>
      <label class="flex-1 flex flex-col items-center gap-2 cursor-pointer group">
        <input type="radio"
               name="answers[<%= question.id %>]"
               value="<%= value %>"
               class="sr-only peer"
               <%= "checked" if current_value == value.to_s %>
               <%= "required" if value == 1 %>>
        <div class="diagnostic-choice w-full min-h-11 py-3 rounded-xl border-2 border-slate-200 text-center text-slate-600 text-sm font-bold
                    peer-checked:border-[var(--color-primary)] peer-checked:bg-[var(--color-primary)] peer-checked:text-secondary-900
                    peer-focus-visible:ring-2 peer-focus-visible:ring-secondary-700 peer-focus-visible:ring-offset-2
                    group-hover:border-slate-400 transition-colors">
          <%= value %>
        </div>
      </label>
    <% end %>
  </div>
  <div class="flex justify-between gap-3 mt-2 text-sm text-slate-500">
    <span>Pas du tout moi</span>
    <span>Tout à fait moi</span>
  </div>
</fieldset>
