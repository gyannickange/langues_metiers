<%# app/views/diagnostics/new.html.erb %>

<div class="min-h-screen bg-background py-10 sm:py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto relative z-10">
    <div class="text-center mb-10">
      <!-- Headers -->
      <div class="text-center mb-10">
        <!-- Back / Home Nuanced Link -->
        <div class="mb-6 flex justify-center">
          <%= link_to root_path, class: "group flex items-center justify-center space-x-2 text-secondary hover:text-primary transition-colors duration-300" do %>
            <span class="text-3xl font-extrabold tracking-tight">
              Insertrice<span class="text-primary">.</span>
            </span>
          <% end %>
        </div>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-secondary mb-4 tracking-tight">
        <%= t('diagnostics.new.title') %>
      </h1>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
        <%= t('diagnostics.new.price_info') %>
        <span class="block mt-2 font-bold text-primary italic text-2xl">
          <%= Diagnostic.formatted_price %>
        </span>
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 items-stretch">
      <!-- Pawapay mobile money -->
      <div class="flex flex-col">
        <div class="bg-secondary rounded-2xl p-6 sm:p-8 shadow-md border border-secondary-700 flex flex-col h-full">
          <h2 class="text-2xl font-bold text-primary mb-6 flex items-center">
            <span class="material-icons mr-2 text-primary">payments</span>
            <%= t('diagnostics.new.momo_title') %>
          </h2>

          <div data-controller="operators" data-operators-url="<%= mobile_operators_path %>" class="flex-grow">
            <%= form_with url: process_payment_diagnostic_path(@diagnostic), class: "space-y-6" do |f| %>
              <%= f.hidden_field :payment_method, value: "pawapay" %>

              <div class="space-y-1">
                <%= f.label :country, t('diagnostics.new.country'), class: "block text-sm font-semibold text-secondary-200 ml-1" %>
                <%= f.select :country,
                      @mobile_operators.keys.sort.map { |c| [c, c] },
                      { selected: @default_country },
                      class: "w-full min-h-11 bg-white border border-secondary-200 rounded-xl px-4 py-3 text-secondary-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary appearance-none cursor-pointer",
                      data: { operators_target: "country", action: "change->operators#updateList" } %>
              </div>

              <div class="space-y-1">
                <%= f.label :phone, t('diagnostics.new.phone'), class: "block text-sm font-semibold text-secondary-200 ml-1" %>
                <%= f.telephone_field :phone, placeholder: t('diagnostics.new.phone_placeholder'), required: true,
                      class: "w-full min-h-11 bg-white border border-secondary-200 rounded-xl px-4 py-3 text-secondary-900 placeholder-slate-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary" %>
              </div>

              <div class="space-y-2">
                <%= f.label :operator_code, t('diagnostics.new.operator'), class: "block text-sm font-semibold text-secondary-200 ml-1" %>
                <div data-operators-target="list" class="grid grid-cols-1 gap-2">
                  <%= render "mobile_operators/list", operators: (@mobile_operators[@default_country] || []) %>
                </div>
              </div>

              <div class="pt-4 mt-auto">
                <button type="submit" class="diagnostic-action w-full min-h-12 bg-primary text-secondary-900 rounded-xl px-6 py-4 font-bold hover:bg-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-secondary transition-colors">
                  <span class="relative z-10 flex items-center justify-center font-bold text-lg">
                    <%= t('diagnostics.new.momo_submit', price: Diagnostic.formatted_price) %>
                    <span class="material-icons ml-2" aria-hidden="true">arrow_forward</span>
                  </span>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Stripe card -->
      <div class="flex flex-col">
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-gray-200 flex flex-col h-full">
          <h2 class="text-2xl font-bold text-secondary mb-6 flex items-center">
            <span class="material-icons mr-2 text-secondary">account_balance</span>
            <%= t('diagnostics.new.stripe_title') %>
          </h2>

          <div class="flex-grow text-gray-600 space-y-4 mb-8">
            <div class="flex items-start space-x-3">
              <span class="material-icons text-green-500 mt-1">check_circle</span>
              <p class="text-sm">Paiement sécurisé par carte bancaire (Visa, Mastercard, etc.)</p>
            </div>
            <div class="flex items-start space-x-3">
              <span class="material-icons text-green-500 mt-1">check_circle</span>
              <p class="text-sm">Accès immédiat à votre diagnostic après confirmation.</p>
            </div>
          </div>

          <div class="mt-auto">
            <%= form_with url: process_payment_diagnostic_path(@diagnostic) do |f| %>
              <%= f.hidden_field :payment_method, value: "stripe" %>
              <button type="submit" class="diagnostic-action w-full min-h-12 bg-secondary text-white rounded-xl px-6 py-4 font-bold hover:bg-secondary-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary-700 focus-visible:ring-offset-2 transition-colors">
                <span class="relative z-10 flex items-center justify-center font-bold text-lg">
                  <%= t('diagnostics.new.stripe_submit', price: Diagnostic.formatted_price) %>
                  <span class="material-icons ml-2">language</span>
                </span>
              </button>
            <% end %>
          </div>
          
          <div class="mt-6 flex items-center justify-center text-gray-500 space-x-4" aria-hidden="true">
             <span class="material-icons">visa</span>
             <span class="material-icons">credit_card</span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mt-12 text-center">
      <p class="text-gray-600 text-sm">
        <span class="material-icons text-xs align-middle mr-1">lock</span>
        Environnement de paiement 100% sécurisé et respectueux de vos données.
      </p>
    </div>
  </div>
</div>
