<%# app/views/diagnostics/skills.html.erb %>
<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-8">
    <p class="text-xs font-bold uppercase text-[var(--color-primary)] mb-2">Étape 3 sur 4</p>
    <h1 class="text-2xl font-bold text-slate-800">Vos compétences</h1>
    <p class="text-slate-500 mt-1">Cochez les compétences dans lesquelles vous vous reconnaissez.</p>
  </div>

  <%= form_with url: submit_skills_diagnostic_path(@diagnostic), method: :post, data: { turbo: false } do |f| %>
    <div class="space-y-3">
      <% if @skills.any? %>
        <% @skills.each do |skill| %>
          <label class="diagnostic-choice flex items-center gap-3 min-h-11 py-3 px-4 bg-white rounded-xl border-2 border-slate-200 cursor-pointer group has-[:checked]:border-[var(--color-primary)] has-[:checked]:bg-primary-50 transition-colors">
            <input type="checkbox" name="selected_skills[]" value="<%= skill.slug %>"
                   class="h-5 w-5 shrink-0 accent-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-secondary-700 focus-visible:ring-offset-2">
            <span class="text-slate-700 font-semibold text-sm"><%= skill.name %></span>
          </label>
        <% end %>
      <% else %>
        <p class="text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3">Aucune compétence spécifique n'est requise pour ces métiers — vous pouvez continuer directement.</p>
      <% end %>
    </div>

    <div class="mt-8">
      <%= f.submit "Continuer vers la validation →",
            class: "diagnostic-action w-full min-h-12 py-4 bg-[var(--color-primary)] text-secondary-900 font-bold rounded-xl hover:bg-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary-700 focus-visible:ring-offset-2 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
