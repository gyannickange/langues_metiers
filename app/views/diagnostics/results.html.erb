<%# app/views/diagnostics/results.html.erb %>
<div class="max-w-6xl mx-auto px-4 sm:px-8 py-10 md:py-16 bg-background min-h-screen font-sans selection:bg-primary-500 selection:text-secondary-900">
  
  <!-- BENTO HEADER -->
  <div class="mb-8 md:mb-12">
    <p class="text-sm font-semibold text-secondary-700 mb-3">Rapport de diagnostic</p>
    <div class="flex flex-col xl:flex-row xl:items-end justify-between gap-8 border-b border-gray-200 pb-8">
      <div>
         <h1 class="text-3xl md:text-4xl font-bold text-secondary-900 leading-tight mb-3">Votre orientation professionnelle</h1>
         <p class="text-sm text-gray-600">Rapport émis le <%= @diagnostic.completed_at&.strftime("%d.%m.%Y") %></p>
      </div>
      
      <!-- Participant specific info in mini-bento -->
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 w-full xl:w-auto text-left">
        <div class="bg-white p-4 rounded-xl border border-gray-200 flex flex-col justify-center">
          <span class="text-sm text-gray-600 font-semibold mb-1">Participant</span>
          <span class="text-sm font-bold text-secondary-900 break-words"><%= [@diagnostic.user.first_name, @diagnostic.user.last_name].filter_map(&:presence).join(" ").presence || "Non renseigné" %></span>
        </div>
        <div class="bg-white p-4 rounded-xl border border-gray-200 flex flex-col justify-center">
          <span class="text-sm text-gray-600 font-semibold mb-1">Localisation</span>
          <span class="text-sm font-bold text-secondary-900 break-words"><%= [@diagnostic.user.city, @diagnostic.user.country].filter_map(&:presence).join(", ").presence || "Non renseignée" %></span>
        </div>
        <div class="bg-white p-4 rounded-xl border border-gray-200 flex flex-col justify-center">
          <span class="text-sm text-gray-600 font-semibold mb-1">Diplôme</span>
          <span class="text-sm font-bold text-secondary-900 break-words"><%= @diagnostic.user.diploma.presence || "Non renseigné" %></span>
        </div>
        <div class="bg-primary-50 p-4 rounded-xl border border-primary-200 flex flex-col justify-center">
          <span class="text-sm text-primary-900 font-semibold mb-1">Statut</span>
          <span class="text-sm font-bold text-primary-900 break-words"><%= @diagnostic.user.employment_status.presence || "Non renseigné" %></span>
        </div>
      </div>
    </div>
  </div>

  <section class="mb-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]" aria-labelledby="result-reading-title">
    <div class="rounded-2xl border border-primary-200 bg-primary-50 p-6 sm:p-8">
      <p class="text-sm font-semibold text-secondary-700 mb-2">Comment lire votre résultat</p>
      <h2 id="result-reading-title" class="text-2xl font-bold text-secondary-900">Un résultat construit à partir de plusieurs signaux</h2>
      <p class="mt-3 max-w-2xl text-base leading-7 text-secondary-900/75"><%= @results.reading_guide %></p>
      <div class="mt-5 flex flex-wrap gap-2 text-sm font-semibold text-secondary-800">
        <span class="rounded-full border border-primary-200 bg-white px-3 py-2">Votre façon de travailler</span>
        <span class="rounded-full border border-primary-200 bg-white px-3 py-2">Vos intérêts</span>
        <span class="rounded-full border border-primary-200 bg-white px-3 py-2">Vos compétences</span>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-8">
      <h2 class="text-xl font-bold text-secondary-900">Pourquoi ce métier vous correspond</h2>
      <% if @results.explanation_factors.any? %>
        <div class="mt-5 space-y-4">
          <% @results.explanation_factors.each do |factor| %>
            <div class="flex gap-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-black text-secondary-800" aria-hidden="true">✓</span>
              <div>
                <h3 class="font-bold text-secondary-900"><%= factor[:title] %></h3>
                <p class="mt-1 text-sm leading-6 text-gray-600"><%= factor[:text] %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-4 text-sm leading-6 text-gray-600">Le détail de l’analyse n’est pas disponible pour ce diagnostic ancien, mais le métier recommandé reste consultable ci-dessous.</p>
      <% end %>
    </div>
  </section>

  <!-- BENTO GRID MAIN AREA -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">
    
    <!-- DOMINANT PROFILE (LARGE HERO CARD) -->
    <div class="lg:col-span-8 bg-secondary rounded-2xl p-6 sm:p-8 md:p-10 flex flex-col justify-between">
      <div>
        <p class="text-sm font-semibold text-primary-400 mb-5">Profil principal</p>
        
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-6 break-words">
          <%= @results.primary_name %>
        </h2>
        
        <p class="text-base md:text-lg text-secondary-100 leading-relaxed max-w-2xl break-words mb-8">
          <%= @results.primary_description %>
        </p>
      </div>

      <% if @results.sectors.any? %>
      <div class="relative z-10">
        <p class="text-sm font-semibold text-primary-400 mb-3">Secteurs associés</p>
        <div class="flex flex-wrap gap-2 md:gap-3">
          <% @results.sectors.each do |env| %>
            <div class="px-3 py-2 bg-white/5 border border-white/15 rounded-lg text-sm font-medium text-white">
              <%= env %>
            </div>
          <% end %>
        </div>
      </div>
      <% end %>
    </div>

    <!-- SECONDARY PROFILE (TALL SIDE CARD) -->
    <div class="lg:col-span-4 bg-white rounded-2xl p-6 sm:p-8 border border-gray-200 flex flex-col">
      <p class="text-sm font-semibold text-secondary-700 mb-5">Profil complémentaire</p>
      
      <h3 class="text-2xl md:text-3xl font-bold text-secondary-900 leading-tight mb-5 break-words">
        <%= @results.secondary_name %>
      </h3>
      
      <p class="text-base text-gray-500 leading-relaxed font-medium mb-10 flex-grow break-words">
        <%= @results.secondary_description %>
      </p>

      <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
        <p class="text-sm font-semibold text-secondary-800 leading-relaxed">
          Lecture du résultat <span class="font-normal text-gray-600 block mt-1">Ce profil arrive juste après votre profil principal dans le diagnostic.</span>
        </p>
      </div>
    </div>

    <!-- FORCES (BENTO BLOCK) -->
    <div class="lg:col-span-6 bg-white rounded-2xl p-6 sm:p-8 border border-gray-200 flex flex-col">
      <div class="flex items-center space-x-3 mb-6">
        <div class="p-2 bg-primary-50 rounded-lg text-secondary-700">
           <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h2 class="text-xl md:text-2xl font-bold text-secondary-900">Compétences clés du métier</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 flex-grow content-start">
        <% @results.key_skills.first(8).each do |force| %>
          <div class="flex items-center space-x-3 p-3 bg-gray-50 rounded-xl border border-gray-200">
            <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shrink-0 border border-gray-200">
               <svg class="w-4 h-4 text-secondary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-semibold text-secondary-900 break-words min-w-0"><%= force %></span>
          </div>
        <% end %>
        <% if @results.key_skills.empty? %>
          <p class="text-sm text-gray-500 leading-relaxed">Aucune compétence clé n'est encore renseignée pour ce métier.</p>
        <% end %>
      </div>
    </div>

    <!-- AXES DE DEVELOPPEMENT (BENTO BLOCK) -->
    <div class="lg:col-span-6 bg-primary-50 rounded-2xl p-6 sm:p-8 border border-primary-200 flex flex-col">
      <div class="flex items-center space-x-3 mb-6">
        <div class="p-2 bg-secondary rounded-lg text-primary-500">
           <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        </div>
        <h2 class="text-xl md:text-2xl font-bold text-secondary-900">Axes de développement</h2>
      </div>

      <div class="flex flex-col gap-3 flex-grow justify-center">
        <% @results.development_axes.each do |axe| %>
          <div class="flex items-center space-x-3 p-4 bg-white rounded-xl border border-primary-200">
            <div class="w-8 h-8 rounded-lg bg-secondary flex items-center justify-center shrink-0">
               <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </div>
            <span class="text-secondary-900 font-bold text-sm md:text-[15px] leading-tight break-words min-w-0"><%= axe %></span>
          </div>
        <% end %>
        <% if @results.development_axes.empty? %>
          <p class="text-sm text-secondary-900/70 leading-relaxed">Aucun axe de développement n'est encore renseigné pour ce métier.</p>
        <% end %>
      </div>
    </div>
  </div>

  <% if @results.first_action %>
  <!-- FIRST ACTION SECTION -->
  <div class="my-12 md:my-16 p-6 sm:p-8 bg-white border border-gray-200 rounded-2xl">
    <p class="text-sm font-semibold text-secondary-700 mb-3">Première action recommandée</p>
    <p class="text-xl md:text-2xl font-bold text-secondary-900 leading-tight max-w-4xl break-words"><%= @results.first_action %></p>
  </div>
  <% end %>

  <% if @results.answer_summary.any? %>
    <section class="mb-12 rounded-2xl border border-gray-200 bg-white p-6 sm:p-8" aria-labelledby="answers-title">
      <details>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-600">
          <span>
            <span class="block text-sm font-semibold text-secondary-700">Votre lecture personnelle</span>
            <span id="answers-title" class="mt-1 block text-xl font-bold text-secondary-900">Voir les réponses prises en compte</span>
          </span>
          <span class="text-sm font-bold text-secondary-700">Ouvrir ▾</span>
        </summary>
        <p class="mt-4 max-w-2xl text-sm leading-6 text-gray-600">Voici vos réponses telles qu’elles ont été enregistrées. Pour les questions graduées, le libellé accompagne toujours la valeur de 1 à 5.</p>
        <div class="mt-6 divide-y divide-gray-100 border-t border-gray-100">
          <% @results.answer_summary.each_with_index do |answer, index| %>
            <div class="grid gap-2 py-4 sm:grid-cols-[8rem_1fr_auto] sm:items-start sm:gap-4">
              <span class="text-xs font-bold uppercase tracking-wide text-gray-500"><%= answer[:kind] %></span>
              <p class="text-sm font-semibold leading-6 text-secondary-900"><%= answer[:question] %></p>
              <span class="justify-self-start rounded-full bg-primary-50 px-3 py-1 text-xs font-bold text-secondary-800 sm:justify-self-end"><%= answer[:value] %> · <%= answer[:label] %></span>
            </div>
          <% end %>
        </div>
      </details>
    </section>
  <% end %>

  <!-- DOWNLOAD ACTION -->
  <div class="flex justify-center pb-20">
    <div class="w-full max-w-xl px-4">
      <% if @diagnostic.pdf_generated? %>
        <%= link_to download_pdf_diagnostic_path(@diagnostic), class: "diagnostic-action group flex items-center justify-between w-full p-4 bg-secondary-900 rounded-xl hover:bg-secondary-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2 transition-colors border border-secondary-900" do %>
          <div class="flex items-center space-x-4">
             <div class="w-11 h-11 rounded-lg bg-white/10 flex items-center justify-center">
               <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
             </div>
             <div class="text-left">
                <p class="text-sm text-primary-400 font-semibold mb-1">Rapport complet</p>
                <p class="text-white font-bold text-lg leading-none">Télécharger le PDF</p>
             </div>
          </div>
          <div class="flex w-11 h-11 rounded-lg border border-white/20 items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </div>
        <% end %>
      <% else %>
        <div id="pdf-status" class="bg-white p-8 rounded-xl border border-primary-200 text-center"
             data-controller="pdf-status"
             data-pdf-status-url-value="<%= pdf_status_diagnostic_path(@diagnostic, format: :json) %>"
             data-pdf-status-interval-value="3000"
             role="status"
             aria-live="polite">
          <div class="flex flex-col items-center space-y-4" data-pdf-status-target="loading">
            <div class="diagnostic-status-pulse rounded-full h-3 w-3 bg-primary-600"></div>
            <div>
              <p class="text-secondary-900 font-bold text-base mb-1">Génération du rapport en cours</p>
              <p class="text-gray-600 text-sm">Le téléchargement sera disponible ici dès qu'il sera prêt.</p>
            </div>
          </div>
          <div class="hidden" data-pdf-status-target="error">
            <p class="text-secondary-900 font-bold mb-4">Impossible de vérifier l'état du PDF.</p>
            <button type="button" data-action="pdf-status#retry" class="diagnostic-action px-5 py-3 bg-secondary-900 text-white rounded-xl font-bold focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
              Réessayer
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
