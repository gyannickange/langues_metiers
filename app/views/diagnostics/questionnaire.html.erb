<%# app/views/diagnostics/questionnaire.html.erb %>
<div class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6 lg:px-8 font-sans text-slate-900">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold text-slate-800 tracking-tight mb-2">
        Diagnostic de Repositionnement
      </h1>
      <p class="text-slate-500 font-medium">Questionnaire stratégique — 25 questions</p>
    </div>

    <!-- Progress Card -->
    <div class="bg-white rounded-[2.5rem] p-8 mb-10 shadow-sm border border-slate-100">
      <div class="flex justify-between items-end mb-6">
        <div>
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase mb-1 block">
            ÉTAPE <%= @current_bloc %> SUR 5
          </span>
          <h2 class="text-xl font-bold text-slate-800"><%= bloc_title(@current_bloc) %></h2>
        </div>
        <div class="text-right">
          <span class="text-xs font-bold text-slate-300 uppercase tracking-wider">
            <%= (@current_bloc - 1) * 20 %>% complété
          </span>
        </div>
      </div>

      <!-- Stepper Indicator -->
      <div class="relative mb-8">
        <div class="absolute top-4 left-0 w-full h-0.5 bg-slate-100"></div>
        <div class="relative flex justify-between">
          <% (1..5).each do |i| %>
            <div class="flex flex-col items-center">
              <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs font-bold z-10 transition-all duration-300
                <%= i <= @current_bloc ? 'stepper-active' : 'bg-white border-slate-100 text-slate-300' %>">
                <%= i %>
              </div>
              <span class="mt-2 text-[9px] font-bold tracking-tighter transition-colors duration-300
                <%= i <= @current_bloc ? 'text-slate-800' : 'text-slate-300' %>">
                <%= bloc_label(i) %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Linear Progress Bar -->
      <div class="w-full bg-slate-50 rounded-full h-1.5 overflow-hidden">
        <div class="progress-fill h-full rounded-full transition-all duration-700 ease-out"
             style="width: <%= (@current_bloc - 1) * 20 %>%"></div>
      </div>
    </div>

    <div class="flex items-center gap-2 mb-8 px-2">
      <h3 class="text-lg font-bold text-slate-800">Questions <%= (@current_bloc - 1) * 5 + 1 %>–<%= @current_bloc * 5 %></h3>
      <span class="text-slate-300 font-medium">sur 25</span>
    </div>

    <%= form_with url: submit_bloc_diagnostic_path(@diagnostic), method: :post, class: "space-y-6" do |f| %>
      <%= f.hidden_field :bloc, value: @current_bloc %>

      <% @questions.each_with_index do |question, index| %>
        <%= render "question", question: question, form: f,
                               number: (@current_bloc - 1) * 5 + index + 1 %>
      <% end %>

      <div class="mt-12 flex justify-center">
        <button type="submit" class="btn-questionnaire group relative flex items-center justify-center gap-3 py-4 px-12 rounded-full font-bold text-lg transition-all duration-300 shadow-lg hover:shadow-xl active:scale-95 min-w-[320px]">
          <%= @current_bloc < 5 ? "Continuer vers l'étape suivante" : "Voir mes résultats" %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </div>

      <div class="mt-12 text-center pb-12">
        <div class="flex items-center justify-center gap-2 text-slate-400 text-xs font-medium mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
          </svg>
          Vos réponses sont sauvegardées automatiquement en temps réel.
        </div>
        <div class="text-[10px] font-bold text-slate-300 tracking-[0.2em] uppercase">
          Insertrice
        </div>
      </div>
    <% end %>
  </div>
</div>
