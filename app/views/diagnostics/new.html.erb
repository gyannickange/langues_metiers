<%# app/views/diagnostics/new.html.erb %>

<div class="min-h-screen bg-[#fbfbfb] py-16 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Background Decorative Elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -right-24 top-1/4 w-64 h-64 bg-primary/10 rounded-full blur-3xl opacity-60"></div>
    <div class="absolute -left-24 bottom-1/4 w-80 h-80 bg-secondary/5 rounded-full blur-3xl opacity-40"></div>
  </div>

  <div class="max-w-4xl mx-auto relative z-10">
    <div class="text-center mb-12 animate-fade-in-up">
      <!-- Headers -->
      <div class="text-center mb-10">
        <!-- Back / Home Nuanced Link -->
        <div class="mb-6 flex justify-center">
          <%= link_to root_path, class: "group flex items-center justify-center space-x-2 text-secondary hover:text-primary transition-colors duration-300" do %>
            <span class="text-3xl font-extrabold tracking-tight">
              Insertrice<span class="text-primary">.</span>
            </span>
          <% end %>
        </div>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-secondary mb-4 tracking-tight">
        <%= t('diagnostics.new.title') %>
      </h1>
      <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto leading-relaxed">
        <%= t('diagnostics.new.price_info') %>
        <span class="block mt-2 font-bold text-primary italic text-2xl">
          <%= Diagnostic.formatted_price %>
        </span>
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 items-stretch">
      <!-- Pawapay mobile money -->
      <div class="flex flex-col animate-fade-in-up" style="animation-delay: 0.1s;">
        <div class="bg-secondary rounded-[2rem] p-8 shadow-2xl relative overflow-hidden group border border-white/5 flex flex-col h-full">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:scale-110 transition-transform">
            <span class="material-icons text-7xl text-white">smartphone</span>
          </div>
          
          <h2 class="text-2xl font-bold text-primary mb-6 flex items-center">
            <span class="material-icons mr-2 text-primary">payments</span>
            <%= t('diagnostics.new.momo_title') %>
          </h2>

          <div data-controller="operators" data-operators-url="<%= mobile_operators_path %>" class="flex-grow">
            <%= form_with url: diagnostics_path, class: "space-y-6" do |f| %>
              <%= f.hidden_field :payment_method, value: "pawapay" %>

              <div class="space-y-1">
                <%= f.label :country, t('diagnostics.new.country'), class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1" %>
                <%= f.select :country,
                      @mobile_operators.keys.sort.map { |c| [c, c] },
                      { selected: @default_country },
                      class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-primary focus:ring-1 focus:ring-primary transition-all appearance-none cursor-pointer",
                      data: { operators_target: "country", action: "change->operators#updateList" } %>
              </div>

              <div class="space-y-1">
                <%= f.label :phone, t('diagnostics.new.phone'), class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1" %>
                <%= f.telephone_field :phone, placeholder: t('diagnostics.new.phone_placeholder'), required: true,
                      class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:border-primary focus:ring-1 focus:ring-primary transition-all" %>
              </div>

              <div class="space-y-2">
                <%= f.label :operator_code, t('diagnostics.new.operator'), class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1" %>
                <div data-operators-target="list" class="grid grid-cols-1 gap-2">
                  <%= render "mobile_operators/list", operators: (@mobile_operators[@default_country] || []) %>
                </div>
              </div>

              <div class="pt-4 mt-auto">
                <button type="submit" class="w-full btn-primary group relative overflow-hidden py-4 shadow-xl">
                  <div class="absolute inset-0 w-full h-full bg-white/20 -skew-x-12 translate-x-full group-hover:0 transition-transform duration-700"></div>
                  <span class="relative z-10 flex items-center justify-center font-bold text-lg">
                    <%= t('diagnostics.new.momo_submit', price: Diagnostic.formatted_price) %>
                    <span class="material-icons ml-2 animate-bounce-slow">arrow_forward</span>
                  </span>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Stripe card -->
      <div class="flex flex-col animate-fade-in-up" style="animation-delay: 0.2s;">
        <div class="bg-white rounded-[2rem] p-8 shadow-xl border border-gray-100 flex flex-col h-full relative overflow-hidden group">
          <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:scale-110 transition-transform">
            <span class="material-icons text-7xl text-secondary">credit_card</span>
          </div>

          <h2 class="text-2xl font-bold text-secondary mb-6 flex items-center">
            <span class="material-icons mr-2 text-secondary">account_balance</span>
            <%= t('diagnostics.new.stripe_title') %>
          </h2>

          <div class="flex-grow text-gray-600 space-y-4 mb-8">
            <div class="flex items-start space-x-3">
              <span class="material-icons text-green-500 mt-1">check_circle</span>
              <p class="text-sm">Paiement sécurisé par carte bancaire (Visa, Mastercard, etc.)</p>
            </div>
            <div class="flex items-start space-x-3">
              <span class="material-icons text-green-500 mt-1">check_circle</span>
              <p class="text-sm">Accès immédiat à votre diagnostic après confirmation.</p>
            </div>
          </div>

          <div class="mt-auto">
            <%= form_with url: diagnostics_path do |f| %>
              <%= f.hidden_field :payment_method, value: "stripe" %>
              <button type="submit" class="w-full btn-secondary group relative overflow-hidden py-4 shadow-xl">
                <div class="absolute inset-0 w-full h-full bg-white/10 -skew-x-12 translate-x-full group-hover:0 transition-transform duration-700"></div>
                <span class="relative z-10 flex items-center justify-center font-bold text-lg">
                  <%= t('diagnostics.new.stripe_submit', price: Diagnostic.formatted_price) %>
                  <span class="material-icons ml-2">language</span>
                </span>
              </button>
            <% end %>
          </div>
          
          <div class="mt-6 flex items-center justify-center opacity-30 grayscale space-x-4">
             <span class="material-icons">visa</span>
             <span class="material-icons">credit_card</span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mt-16 text-center animate-fade-in-up" style="animation-delay: 0.3s;">
      <p class="text-gray-400 text-sm italic">
        <span class="material-icons text-xs align-middle mr-1">lock</span>
        Environnement de paiement 100% sécurisé et respectueux de vos données.
      </p>
    </div>
  </div>
</div>
