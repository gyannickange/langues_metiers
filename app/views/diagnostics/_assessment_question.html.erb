<%# app/views/diagnostics/_assessment_question.html.erb %>
<div class="bg-white rounded-[2.5rem] p-8 shadow-sm border border-slate-100 mb-6">
  <div class="flex items-center gap-4 mb-6">
    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-secondary flex items-center justify-center text-secondary-foreground text-sm font-bold mt-1">
      <%= number %>
    </div>
    <h3 class="text-xl font-bold text-slate-800 leading-tight">
      <%= assessment_question.text %>
    </h3>
  </div>

  <% if assessment_question.kind == "likert" %>
    <div class="px-2">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Pas du tout</span>
        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Tout à fait</span>
      </div>
      <div class="flex justify-between items-center gap-2">
        <% (1..5).each do |val| %>
          <label class="assessment-question-option group relative flex flex-col items-center cursor-pointer flex-1">
            <%= form.radio_button "answers[#{assessment_question.id}]", val.to_s, required: true,
                  class: "sr-only" %>
            <div class="option-box w-full py-4 border-2 border-slate-100 rounded-2xl flex flex-col items-center gap-2 transition-all duration-200">
              <div class="radio-dot w-5 h-5 rounded-full border-2 border-slate-200 flex items-center justify-center relative transition-all duration-200"></div>
              <span class="text-sm font-bold text-slate-500 transition-colors duration-200"><%= val %></span>
            </div>
          </label>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="space-y-3">
      <% assessment_question.options.each do |opt| %>
        <label class="assessment-question-option group block cursor-pointer">
          <%= form.radio_button "answers[#{assessment_question.id}]", opt["value"], required: true,
                class: "sr-only" %>
          <div class="option-box flex items-center gap-4 p-5 border-2 border-slate-100 rounded-3xl transition-all duration-200">
            <div class="radio-dot flex-shrink-0 w-6 h-6 rounded-full border-2 border-slate-200 flex items-center justify-center relative transition-all duration-200"></div>
            <div class="text-slate-700 font-medium">
              <% if opt["label"].present? %>
                <span class="font-bold text-slate-900"><%= opt["label"] %>.</span>
                <% if opt["text"].present? %> <%= opt["text"] %><% end %>
              <% else %>
                <%= opt["value"] %>
              <% end %>
            </div>
          </div>
        </label>
      <% end %>
    </div>
  <% end %>
</div>

