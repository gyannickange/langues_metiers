<% content_for :page_title, "Compétences" %>

<%= render "shared/page_header", 
    title: "Compétences",
    subtitle: "Gérer le référentiel des compétences techniques et transversales",
    action_text: "Nouvelle Compétence",
    action_url: new_admin_skill_path,
    action_icon: :plus %>

<%= render "shared/table",
  columns: [
    { header: "Nom",  cell: ->(s){ link_to s.name, admin_skill_path(s), class: "text-[var(--color-primary)] font-bold hover:underline" } },
    { header: "Description", cell: ->(s){ content_tag(:span, truncate(s.description.to_s, length: 80), class: "text-slate-500") } }
  ],
  rows: @skills,
  pagy: @pagy,
  actions: ->(s){
    capture do %>
      <%= link_to edit_admin_skill_path(s), class: "p-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition-colors" do %>
        <%= lucide_icon :edit_3, class: "w-4 h-4" %>
      <% end %>
      <%= button_to admin_skill_path(s), method: :delete, data: { turbo_confirm: t("admin.shared.confirm_delete") }, class: "p-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors border-0" do %>
        <%= lucide_icon :trash_2, class: "w-4 h-4" %>
      <% end %>
    <% end
  } %>
