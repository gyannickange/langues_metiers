<% content_for :page_title, "Détails du Diagnostic" %>

<%= render "shared/page_header", 
    title: "Diagnostic",
    subtitle: "Consulter les détails du diagnostic et les résultats associés",
    action_text: "Retour aux diagnostics",
    action_url: admin_diagnostics_path,
    action_icon: :arrow_left,
    action_type: :secondary %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2 space-y-8">
    <%= render "shared/show_card", 
        title: "Informations Générales",
        icon: :info,
        items: [
          { label: "Utilisateur", value: @diagnostic.user&.email },
          { label: "Statut", value: render("shared/badge", text: @diagnostic.status, color: @diagnostic.completed? ? :green : :gray) },
          { label: "Profil Principal", value: @diagnostic.primary_profile&.name || "—" },
          { label: "Profil Complémentaire", value: @diagnostic.complementary_profile&.name || "—" },
          { label: "Créé le", value: l(@diagnostic.created_at, format: :long) },
          { label: "Fournisseur", value: content_tag(:span, @diagnostic.payment_provider, class: "font-mono text-xs uppercase") }
        ] %>

    <% if @diagnostic.diagnostic_answers.any? %>
      <div class="glass-card rounded-2xl p-6 shadow-premium animate-premium-in" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-6 border-b border-slate-100 pb-4">
          <div class="p-2 bg-[var(--color-primary)]/10 text-[var(--color-primary)] rounded-lg">
            <%= lucide_icon :list_checks, class: "w-5 h-5" %>
          </div>
          <h3 class="text-lg font-display uppercase tracking-wider text-slate-800">
            Réponses (<%= @diagnostic.diagnostic_answers.count %>)
          </h3>
        </div>
        <div class="bg-slate-50/50 rounded-xl p-4 font-mono text-xs text-slate-600 overflow-auto max-h-96">
          <%= @diagnostic.score_data %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-8">
    <% if @diagnostic.payment %>
      <%= render "shared/show_card", 
          title: "Paiement",
          icon: :credit_card,
          items: [
            { label: "Statut", value: render("shared/badge", text: @diagnostic.payment.status, color: @diagnostic.payment.completed? ? :green : :orange) },
            { label: "Montant", value: number_to_currency(@diagnostic.payment.amount, unit: "CFA ", precision: 0) }
          ] %>
    <% end %>

    <div class="glass-card rounded-2xl p-6 shadow-premium animate-premium-in border-l-4 border-[var(--color-primary)]" style="animation-delay: 0.2s;">
      <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4">Export PDF</h4>
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-slate-700">Généré ?</span>
        <%= render "shared/badge", text: (@diagnostic.pdf_generated? ? "Oui" : "Non"), color: (@diagnostic.pdf_generated? ? :green : :gray) %>
      </div>
    </div>
  </div>
</div>
