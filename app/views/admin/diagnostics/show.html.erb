<% content_for :page_title, "Détails du Diagnostic - #{@diagnostic.user&.email}" %>

<%= render "shared/page_header", 
    title: "Diagnostic ##{@diagnostic.id.to_s.split('-').first}",
    subtitle: "Résultats du questionnaire pour #{@diagnostic.user&.email}",
    action_text: "Retour",
    action_url: admin_diagnostics_path,
    action_icon: "arrow-left",
    action_type: :secondary %>

<div class="space-y-8">
  <!-- Top Side: Detail Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <%= render "shared/show_card", 
        title: "Session",
        icon: :info,
        show_border: true,
        items: [
          { label: "Statut", value: render("shared/badge", label: @diagnostic.status, color: @diagnostic.completed? ? :green : :gray) },
          { label: "Utilisateur", value: @diagnostic.user&.email },
          { label: "Créé le", value: l(@diagnostic.created_at, format: :short) }
        ] %>

    <% if @diagnostic.completed? %>
      <%= render "shared/show_card", 
          title: "Orientation",
          icon: :compass,
          show_border: true,
          action: { text: "Voir le Résultat", url: results_diagnostic_path(@diagnostic), target: "_blank" },
          items: [
            { label: "Métier 1", value: content_tag(:span, @diagnostic.primary_career&.title || "—", class: "font-bold text-[var(--color-primary)]") },
            { label: "Métier 2", value: @diagnostic.complementary_career&.title || "—" }
          ] %>
    <% end %>

    <%= render "shared/show_card", 
        title: "Export Rapport",
        icon: "file-text",
        show_border: true,
        items: [
          { label: "PDF Généré", value: render("shared/badge", label: (@diagnostic.pdf_generated? ? "OUI" : "NON"), color: (@diagnostic.pdf_generated? ? :green : :gray)) }
        ] %>
  </div>

  <!-- Bottom Side: Answers -->
  <div>
    <div class="glass-card rounded-[2rem] shadow-premium min-h-[600px]">
      <div class="animate-premium-in">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 pb-6 border-b border-slate-100">
          <div>
            <h3 class="text-xl font-bold text-slate-800">Détail des Réponses</h3>
            <p class="text-slate-400 text-xs font-medium mt-1">Réponses du diagnostic</p>
          </div>
          <% if @attribution.available? %>
            <div class="text-xs font-bold text-slate-500 tracking-wide">
              <%= @attribution.recap_line %>
            </div>
          <% end %>
        </div>

        <% affirmation_rows = @attribution.affirmation_rows %>
        <% if @answers.any? || affirmation_rows.any? %>
          <div class="space-y-4">
            <% @answers.each_with_index do |answer, idx| %>
              <div class="p-6 rounded-2xl bg-white border border-slate-100 hover:border-[var(--color-primary)]/20 hover:shadow-premium-sm transition-all group">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-[10px] font-black text-slate-400 border border-slate-100">
                    <%= idx + 1 %>
                  </div>
                  <div class="flex-1">
                    <p class="text-slate-800 font-bold leading-relaxed mb-3">
                      <%= answer.diagnostic_question.text %>
                    </p>
                    <div class="flex flex-col items-start gap-2 mt-4">
                       <span class="text-[10px] font-black text-slate-300">Réponse :</span>
                       <span class="px-3 py-1 bg-green-50 text-green-700 text-xs font-bold rounded-lg border border-green-100">
                         <% selected_option = answer.diagnostic_question.options&.find { |o| o["value"] == answer.answer_value } %>
                         <%= selected_option ? "#{answer.answer_value}: #{selected_option['text']}" : answer.answer_value %>
                       </span>
                    </div>
                    <% badges = @attribution.badges_for(answer) %>
                    <% if badges.any? %>
                      <div class="flex flex-wrap items-center gap-2 mt-3">
                        <% badges.each do |badge| %>
                          <span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-[10px] font-black rounded-lg border border-indigo-100 tracking-wide">
                            <%= badge[:label] %> · +<%= badge[:points] %> pts
                          </span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>

            <% affirmation_rows.each_with_index do |row, idx| %>
              <div class="p-6 rounded-2xl bg-white border border-slate-100 hover:border-[var(--color-primary)]/20 hover:shadow-premium-sm transition-all group">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-[10px] font-black text-slate-400 border border-slate-100">
                    <%= @answers.size + idx + 1 %>
                  </div>
                  <div class="flex-1">
                    <p class="text-slate-800 font-bold leading-relaxed mb-3">
                      Affirmation validée pour <%= row[:label] %> : « <%= row[:text] %> »
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "shared/empty_state",
                     icon: "clipboard-list",
                     title: "Aucune réponse",
                     description: "Aucune donnée enregistrée pour ce diagnostic." %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @diagnostic.payment %>
    <!-- Footer Side: Paiement -->
    <div class="mt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%= render "shared/show_card", 
            title: "Paiement",
            icon: :credit_card,
            show_border: true,
            items: [
              { label: "Statut", value: render("shared/badge", label: @diagnostic.payment.status, color: @diagnostic.payment.confirmed? ? :green : :orange) },
              { label: "Montant", value: number_to_currency(@diagnostic.payment.amount_cents / 100, unit: "CFA ", precision: 0) },
              { label: "Méthode", value: content_tag(:span, @diagnostic.payment_provider&.upcase, class: "font-mono text-[10px]") }
            ] %>
      </div>
    </div>
  <% end %>
</div>
