<% content_for :page_title, "Détails du Diagnostic - #{@diagnostic.user&.email}" %>

<%= render "shared/page_header", 
    title: "Diagnostic ##{@diagnostic.id.to_s.split('-').first}",
    subtitle: "Résultats du questionnaire pour #{@diagnostic.user&.email}",
    action_text: "Retour",
    action_url: admin_diagnostics_path,
    action_icon: "arrow-left",
    action_type: :secondary %>

<div class="space-y-8">
  <!-- Top Side: Detail Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <%= render "shared/show_card", 
        title: "Session",
        icon: :info,
        show_border: true,
        items: [
          { label: "Statut", value: render("shared/badge", label: @diagnostic.status, color: @diagnostic.completed? ? :green : :gray) },
          { label: "Utilisateur", value: @diagnostic.user&.email },
          { label: "Créé le", value: l(@diagnostic.created_at, format: :short) }
        ] %>

    <% if @diagnostic.completed? %>
      <%= render "shared/show_card", 
          title: "Orientation",
          icon: :compass,
          show_border: true,
          action: { text: "Voir le Résultat", url: results_diagnostic_path(@diagnostic), target: "_blank" },
          items: [
            { label: "Métier 1", value: content_tag(:span, @diagnostic.primary_career&.title || "—", class: "font-bold text-[var(--color-primary)]") },
            { label: "Métier 2", value: @diagnostic.complementary_career&.title || "—" }
          ] %>
    <% end %>

    <%= render "shared/show_card", 
        title: "Export Rapport",
        icon: "file-text",
        show_border: true,
        items: [
          { label: "PDF Généré", value: render("shared/badge", label: (@diagnostic.pdf_generated? ? "OUI" : "NON"), color: (@diagnostic.pdf_generated? ? :green : :gray)) }
        ] %>
  </div>

  <%= render "admin/diagnostics/score_overview", attribution: @attribution %>

  <!-- Answer audit -->
  <div>
    <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm sm:p-8">
      <div class="mb-6 flex flex-col gap-3 border-b border-slate-100 pb-6 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-wide text-[var(--color-primary)]">Trace des réponses</p>
          <h3 class="mt-1 text-2xl font-bold text-slate-800">Réponse par réponse</h3>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-500">Chaque ligne indique ce que l’utilisateur a choisi, la règle appliquée et les métiers qui en ont bénéficié.</p>
        </div>
        <span class="text-xs font-bold text-slate-400"><%= @answers.size + @attribution.affirmation_rows.size %> éléments analysables</span>
      </div>

      <% affirmation_rows = @attribution.affirmation_rows %>
      <% if @answers.any? || affirmation_rows.any? %>
        <div data-controller="answer-filter"
             data-answer-filter-active-class="bg-[var(--color-secondary)] text-white shadow-sm"
             data-answer-filter-inactive-class="bg-white text-slate-500 hover:text-slate-800">
          <div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="Filtrer les réponses">
            <% [["all", "Toutes"], ["disc", "DISC"], ["interest", "Intérêts"], ["skill", "Compétences"], ["affirmation", "Affirmations"], ["scored", "Ont compté"]].each_with_index do |(value, text), i| %>
              <button type="button"
                      class="min-h-11 rounded-full border border-slate-200 px-3 py-2 text-xs font-bold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 <%= i.zero? ? "bg-[var(--color-secondary)] text-white shadow-sm" : "bg-white text-slate-500 hover:text-slate-800" %>"
                      data-answer-filter-target="button"
                      data-action="click->answer-filter#filter"
                      aria-pressed="<%= i.zero? %>"
                      data-answer-filter-filter-param="<%= value %>">
                <%= text %>
              </button>
            <% end %>
            <% @attribution.score_summary.each do |summary| %>
              <button type="button"
                      class="min-h-11 rounded-full border border-slate-200 bg-white px-3 py-2 text-xs font-bold text-slate-500 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 hover:text-slate-800"
                      data-answer-filter-target="button"
                      data-action="click->answer-filter#filter"
                      aria-pressed="false"
                      data-answer-filter-filter-param="career-<%= summary[:career].id %>">
                <%= summary[:label] %>
              </button>
            <% end %>
          </div>

          <div class="space-y-3">
            <% @answers.each_with_index do |answer, idx| %>
              <% details = @attribution.contribution_details_for(answer) %>
              <% career_ids = details.map { |detail| detail[:career].id }.join(",") %>
              <article class="rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-slate-300"
                       data-answer-filter-target="row"
                       data-category="<%= answer.diagnostic_question.kind %>"
                       data-scored="<%= details.any? %>"
                       data-careers="<%= career_ids %>">
                <div class="flex gap-4">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xs font-black text-slate-500"><%= idx + 1 %></div>
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <span class="text-xs font-bold text-slate-400"><%= @attribution.question_kind_label(answer.diagnostic_question) %></span>
                        <h4 class="mt-1 font-bold leading-6 text-slate-800"><%= answer.diagnostic_question.text %></h4>
                      </div>
                      <span class="shrink-0 rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600">Réponse <%= answer.answer_value %></span>
                    </div>

                    <div class="mt-4 rounded-xl bg-slate-50 p-4">
                      <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Choix de l’utilisateur</p>
                      <p class="mt-1 font-bold text-slate-800"><%= @attribution.answer_value_label(answer) %></p>
                    </div>

                    <% if details.any? %>
                      <div class="mt-4 space-y-2">
                        <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Contribution au calcul</p>
                        <% details.each do |detail| %>
                          <div class="flex flex-col gap-1 rounded-xl border border-emerald-100 bg-emerald-50/60 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                              <p class="text-sm font-bold text-emerald-950"><%= detail[:label] %> · <%= detail[:career].title %></p>
                              <p class="text-xs leading-5 text-emerald-900/70"><%= detail[:rule] %> — <%= detail[:text] %></p>
                            </div>
                            <span class="shrink-0 text-sm font-black text-emerald-800">+<%= detail[:points] %> pts</span>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mt-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-500"><%= @attribution.no_contribution_text(answer.diagnostic_question) %> Elle reste visible pour contrôler l’intégralité des réponses.</p>
                    <% end %>
                  </div>
                </div>
              </article>
            <% end %>

            <% affirmation_rows.each_with_index do |row, idx| %>
              <article class="rounded-2xl border border-amber-200 bg-amber-50/50 p-5"
                       data-answer-filter-target="row"
                       data-category="affirmation"
                       data-scored="true"
                       data-careers="<%= row[:career_id] %>">
                <div class="flex gap-4">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-amber-100 text-xs font-black text-amber-700"><%= @answers.size + idx + 1 %></div>
                  <div>
                    <p class="text-xs font-bold uppercase tracking-wide text-amber-700">Affirmation validée</p>
                    <p class="mt-1 font-bold leading-6 text-slate-800"><%= row[:label] %> · « <%= row[:text] %> »</p>
                    <p class="mt-2 text-sm text-slate-600">Cette validation a ajouté un bonus au score du métier concerné.</p>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
          <p class="mt-6 rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-5 py-8 text-center text-sm text-slate-500" data-answer-filter-target="empty" hidden>
            Aucune réponse ne correspond à ce filtre.
          </p>
        </div>
      <% else %>
        <%= render "shared/empty_state",
                   icon: "clipboard-list",
                   title: "Aucune réponse",
                   description: "Aucune donnée enregistrée pour ce diagnostic." %>
      <% end %>
    </div>
  </div>

  <% if @diagnostic.payment %>
    <!-- Footer Side: Paiement -->
    <div class="mt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%= render "shared/show_card", 
            title: "Paiement",
            icon: :credit_card,
            show_border: true,
            items: [
              { label: "Statut", value: render("shared/badge", label: @diagnostic.payment.status, color: @diagnostic.payment.confirmed? ? :green : :orange) },
              { label: "Montant", value: number_to_currency(@diagnostic.payment.amount_cents / 100, unit: "CFA ", precision: 0) },
              { label: "Méthode", value: content_tag(:span, @diagnostic.payment_provider&.upcase, class: "font-mono text-[10px]") }
            ] %>
      </div>
    </div>
  <% end %>
</div>
