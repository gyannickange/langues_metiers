<% content_for :page_title, "Diagnostics" %>

<%= render "shared/page_header", 
    title: "Diagnostics",
    subtitle: "Gérer les diagnostics et résultats des utilisateurs",
    action_text: nil,
    action_url: nil %>

<div class="mb-6 flex items-center justify-between animate-premium-in">
  <!-- Status Tabs -->
  <div class="flex flex-wrap items-center gap-1 bg-slate-100/50 p-1.5 rounded-2xl border border-slate-100"
       data-controller="tab-activation"
       data-tab-activation-active-class="bg-white text-[var(--color-primary)] shadow-sm border border-slate-100"
       data-tab-activation-inactive-class="text-slate-400 hover:text-slate-600">
    <% ['all', 'completed', 'in_progress', 'paid', 'pending_payment'].each do |status| %>
      <%= link_to admin_diagnostics_path(status: status), 
                  class: "px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 #{@status_filter == status ? "bg-white text-[var(--color-primary)] shadow-sm border border-slate-100" : "text-slate-400 hover:text-slate-600"}",
                  data: { turbo_frame: "diagnostics_table", turbo_action: "advance", tab_activation_target: "tab", action: "click->tab-activation#activate" } do %>
        <%= status == 'all' ? "TOUS" : t("activerecord.attributes.diagnostic.statuses.#{status}", default: status).humanize.upcase %>
      <% end %>
    <% end %>
  </div>
</div>

<%= turbo_frame_tag "diagnostics_table" do %>
  <% if @diagnostics.any? %>
    <%= render "shared/table",
        columns: [
          { header: "Utilisateur", cell: ->(d){ d.user&.email } },
          { header: "Statut", cell: ->(d){ render "shared/badge", label: d.status, color: d.completed? ? :green : (d.in_progress? ? :blue : :gray) } },
          { header: "Profil principal", cell: ->(d){ d.primary_career&.title || "—" } },
          { header: "Créé le", cell: ->(d){ l(d.created_at, format: :short) } }
        ],
        rows: @diagnostics,
        pagy: @pagy,
        actions: ->(d){
          link_to admin_diagnostic_path(d), class: "inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 rounded-lg text-xs font-bold hover:bg-slate-200 transition-colors", data: { turbo_frame: "_top" } do
            lucide_icon "eye", class: "w-3 h-3 mr-1.5"
            "Voir"
          end
        } %>
  <% else %>
    <%= render "shared/empty_state", 
               icon: "list-checks",
               title: "Aucun diagnostic",
               description: "Aucun diagnostic trouvé pour ce statut." %>
  <% end %>
<% end %>
