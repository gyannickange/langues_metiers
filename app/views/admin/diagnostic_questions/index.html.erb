<%# app/views/admin/diagnostic_questions/index.html.erb %>
<% content_for :page_title, "Questions du Diagnostic" %>

<%= link_to edit_admin_assessment_path(@assessment), class: "inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-slate-600 transition-colors mb-4" do %>
  <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
  Retour à l'évaluation
<% end %>

<%= render "shared/page_header",
    title: "Questions : #{@assessment.title}",
    subtitle: "Gérer les questions DISC, intérêt thématique et skills",
    action_text: "Nouvelle Question",
    action_url: new_admin_assessment_diagnostic_question_path(@assessment, kind: (@kind_filter == "all" ? nil : @kind_filter)),
    action_icon: "plus" %>

<div class="mb-6 flex gap-2">
  <% [["all", "Toutes"], ["interest", "Intérêt"], ["disc", "DISC"], ["skill", "Skill"]].each do |kind, label| %>
    <%= link_to label,
          admin_assessment_diagnostic_questions_path(@assessment, kind: kind),
          class: "px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-widest transition-all #{@kind_filter == kind ? "bg-[var(--color-primary)] text-white" : "bg-slate-100 text-slate-500 hover:bg-slate-200"}" %>
  <% end %>
</div>

<% sortable_enabled = @kind_filter != "all" %>
<div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-200">
      <tr>
        <% if sortable_enabled %><th class="px-4 py-3 w-8"></th><% end %>
        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-slate-400">Type</th>
        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-slate-400">Question</th>
        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-slate-400">Métadonnée</th>
        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-slate-400">Pos.</th>
        <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-widest text-slate-400">Active</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100"
        <% if sortable_enabled %>
          data-controller="sortable"
          data-sortable-url-value="<%= reorder_admin_assessment_diagnostic_questions_path(@assessment, kind: @kind_filter) %>"
        <% end %>>
      <%= render partial: "question_row", collection: @questions, as: :q,
            locals: { assessment: @assessment, sortable_enabled: sortable_enabled, kind_filter: @kind_filter } %>
    </tbody>
  </table>
</div>
