<%# app/views/admin/diagnostic_questions/new.html.erb %>
<% content_for :page_title, "Nouvelle Question" %>

<%= render "shared/page_header",
    title: "Nouvelle Question du Diagnostic",
    subtitle: "Évaluation : #{@assessment.title}",
    action_text: "Retour",
    action_url: admin_assessment_diagnostic_questions_path(@assessment),
    action_icon: "arrow-left" %>

<%= render "form", question: @question, assessment: @assessment %>
