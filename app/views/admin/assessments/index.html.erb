<% content_for :page_title, "Évaluations" %>

<%= render "shared/page_header", 
    title: "Évaluations",
    subtitle: "Gérer les différents modèles de diagnostic",
    action_text: "Nouvelle Évaluation",
    action_url: new_admin_assessment_path,
    action_icon: "plus" %>

<%= render "shared/table",
  columns: [
    { header: "Titre", cell: ->(a){ content_tag(:div, a.title, class: "font-bold text-slate-800") } },
    { header: "Description", cell: ->(a){ content_tag(:div, a.description&.truncate(60), class: "text-slate-500 text-sm") } },
    { header: "Questions", cell: ->(a){ content_tag(:span, a.assessment_questions.count, class: "font-mono font-bold text-xs bg-slate-100 px-2 py-0.5 rounded text-slate-600") } },
    { header: "Blocs", cell: ->(a){ content_tag(:span, a.total_blocs, class: "font-mono font-bold text-xs bg-slate-100 px-2 py-0.5 rounded text-slate-600") } },
    { header: "Statut", cell: ->(a){ render "shared/badge", text: (a.active? ? "Actif" : "Inactif"), color: (a.active? ? :green : :gray) } }
  ],
  rows: @assessments,
  pagy: @pagy,
  actions: ->(a){
    capture do %>
      <% unless a.active? %>
        <%= button_to activate_admin_assessment_path(a), method: :patch, class: "mr-2 p-2 bg-green-50 text-green-600 rounded-lg hover:bg-green-100 transition-colors border-0", title: "Activer" do %>
          <%= lucide_icon "check-circle", class: "w-4 h-4" %>
        <% end %>
      <% end %>
      
      <%= link_to admin_assessment_assessment_questions_path(a), class: "mr-2 p-2 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-100 transition-colors", title: "Voir les questions" do %>
        <%= lucide_icon "list", class: "w-4 h-4" %>
      <% end %>

      <%= link_to edit_admin_assessment_path(a), class: "mr-2 p-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition-colors" do %>
        <%= lucide_icon "edit-3", class: "w-4 h-4" %>
      <% end %>
      
      <%= button_to admin_assessment_path(a), method: :delete, data: { turbo_confirm: "Confirmer la suppression ?" }, class: "p-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors border-0" do %>
        <%= lucide_icon "trash-2", class: "w-4 h-4" %>
      <% end %>
    <% end
  } %>

