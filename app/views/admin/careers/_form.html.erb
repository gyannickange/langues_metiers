<div class="glass-card rounded-2xl p-8 shadow-premium animate-premium-in max-w-2xl">
  <%= form_with model: [:admin, career], class: "space-y-6" do |f| %>
    <% if career.errors.any? %>
      <div class="bg-red-50 border border-red-100 p-4 rounded-xl text-sm text-red-700 mb-6 animate-shake">
        <div class="font-bold flex items-center gap-2 mb-1">
          <%= lucide_icon "alert-circle", class: "w-4 h-4" %>
          <%= t("errors.messages.not_saved", count: career.errors.count, resource: "métier") %>
        </div>
        <ul class="list-disc list-inside opacity-90">
          <% career.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :title, label: "Titre", type: "text", placeholder: "Ex: Traducteur / Interprète" } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :description, label: "Description", type: "text_area", rows: 6, placeholder: "Décrivez les missions et responsabilités..." } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :status, label: "Statut", type: "select",
          options: Career.statuses.keys.map { |k| [k.humanize, k] } } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :academic_field_slug, label: "Filières académiques", type: "select",
          options: Diagnostics::Vocabulary.academic_field_options, include_blank: "— choisir —" } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :disc_types, label: "Types DISC", type: "checkbox_collection",
          collection: Diagnostics::Vocabulary::DISC_TYPES.to_a, value_method: :first, text_method: :last, layout: "inline" } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :required_skills, label: "Compétences requises", type: "checkbox_collection",
          collection: Diagnostics::Vocabulary.skill_options, value_method: :last, text_method: :first, layout: "grid" } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :affirmations_text, label: "Affirmations (une par ligne)", type: "text_area", rows: 6, placeholder: "Une affirmation par ligne..." } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :first_action, label: "Première action", type: "text_area", rows: 3 } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :premium_pitch, label: "Pitch premium", type: "text_area", rows: 3 } %>

    <div class="pt-4 flex items-center gap-4">
      <%= f.submit t("Save"), class: "bg-[var(--color-primary)] text-white px-8 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-all shadow-sm transform hover:translate-y-[-1px]" %>
      <%= link_to t("Cancel"), admin_careers_path, class: "text-slate-400 text-xs font-bold hover:text-slate-600 transition-colors" %>
    </div>
  <% end %>
</div>
