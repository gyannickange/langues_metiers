<% content_for :page_title, t("Careers") %>

<%= render "shared/page_header", 
    title: t("Careers"),
    subtitle: "Gérer les métiers et opportunités professionnelles",
    action_text: t("New Career"),
    action_url: new_admin_career_path,
    action_icon: :plus %>

<div class="mb-6 flex flex-wrap gap-4 items-center bg-white/50 backdrop-blur-sm p-4 rounded-2xl border border-slate-100/50 shadow-sm animate-premium-in" data-controller="filters">
  <%= form_with url: admin_careers_path, method: :get, data: { turbo_frame: "careers" }, class: "flex items-center gap-4 w-full" do %>
    <div class="relative flex-1 max-w-md">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
        <%= lucide_icon :search, class: "w-4 h-4" %>
      </div>
      <input type="text" name="q" value="<%= @query %>" placeholder="<%= t("Search careers") %>..." 
             class="block w-full pl-10 pr-3 py-2.5 border-0 bg-slate-50 rounded-xl text-sm placeholder:text-slate-400 focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all font-medium" 
             data-filters-target="query" data-action="input->filters#submit" />
    </div>

    <div class="flex items-center space-x-2">
      <label class="text-[10px] font-black uppercase tracking-widest text-slate-400"><%= t("Status") %></label>
      <select name="status" class="bg-slate-50 border-0 rounded-xl px-4 py-2.5 text-sm font-bold text-slate-600 focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all cursor-pointer" 
              data-filters-target="status" data-action="change->filters#submit">
        <option value=""><%= t("All statuses") %></option>
        <% Career.statuses.keys.each do |st| %>
          <option value="<%= st %>" <%= "selected" if st == @status %>><%= st.humanize %></option>
        <% end %>
      </select>
    </div>
  <% end %>
</div>

<%= turbo_frame_tag "careers" do %>
  <%= render "shared/table",
    columns: [
      { header: "Titre",  cell: ->(r){ content_tag(:span, r.title, class: "font-bold text-slate-800") } },
      { header: "Statut", cell: ->(r){ render "shared/badge", text: r.status, color: (r.active? ? :green : :gray) } }
    ],
    rows: @careers,
    pagy: @pagy,
    actions: ->(r){
      capture do %>
        <%= link_to edit_admin_career_path(r), class: "p-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition-colors" do %>
          <%= lucide_icon :edit_3, class: "w-4 h-4" %>
        <% end %>
        <%= button_to admin_career_path(r), method: :delete, data: { turbo_confirm: t("Are you sure?") }, class: "p-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors border-0" do %>
          <%= lucide_icon :trash_2, class: "w-4 h-4" %>
        <% end %>
      <% end
    } %>
<% end %>


