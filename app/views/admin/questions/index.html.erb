<% content_for :page_title, "Questions" %>

<%= render "shared/page_header", 
    title: "Questions",
    subtitle: "Gérer les blocs de questions du diagnostic",
    action_text: "Nouvelle Question",
    action_url: new_admin_question_path,
    action_icon: :plus %>

<%= render "shared/table",
  columns: [
    { header: "Bloc", cell: ->(q){ render "shared/badge", text: q.bloc, color: :blue } },
    { header: "Pos.", cell: ->(q){ content_tag(:span, q.position, class: "font-mono font-bold text-[10px] bg-slate-100 px-2 py-0.5 rounded") } },
    { header: "Texte de la question", cell: ->(q){ content_tag(:div, q.text&.truncate(100), class: "max-w-md whitespace-normal leading-tight") } },
    { header: "Type", cell: ->(q){ content_tag(:span, q.kind&.upcase, class: "text-[10px] font-black text-slate-400 tracking-widest") } },
    { header: "Statut", cell: ->(q){ render "shared/badge", text: (q.active? ? "Active" : "Inactive"), color: (q.active? ? :green : :gray) } }
  ],
  rows: @questions,
  pagy: @pagy,
  actions: ->(q){
    capture do %>
      <%= link_to edit_admin_question_path(q), class: "p-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition-colors" do %>
        <%= lucide_icon :edit_3, class: "w-4 h-4" %>
      <% end %>
      <%= button_to admin_question_path(q), method: :delete, data: { turbo_confirm: "Confirmer la suppression ?" }, class: "p-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors border-0" do %>
        <%= lucide_icon :trash_2, class: "w-4 h-4" %>
      <% end %>
    <% end
  } %>
