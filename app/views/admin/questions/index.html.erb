<% content_for :page_title, "Questions" %>

<%= render "shared/page_header", 
    title: @questionnaire ? "Questions: #{@questionnaire.title}" : "Questions",
    subtitle: @questionnaire ? "Gérer les questions de ce modèle" : "Gérer toutes les questions",
    action_text: "Nouvelle Question",
    action_url: @questionnaire ? new_admin_questionnaire_question_path(@questionnaire) : new_admin_question_path,
    action_icon: "plus" %>

<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6 animate-premium-in">
  <div class="flex flex-col md:flex-row gap-4 w-full md:w-auto">
    <!-- Status Tabs -->
    <div class="flex items-center gap-1 bg-slate-100/50 p-1.5 rounded-2xl border border-slate-100"
         data-controller="tab-activation"
         data-tab-activation-active-class="bg-white text-[var(--color-primary)] shadow-sm border border-slate-100"
         data-tab-activation-inactive-class="text-slate-400 hover:text-slate-600">
      <%= link_to (@questionnaire ? admin_questionnaire_questions_path(@questionnaire, bloc: @current_bloc, status: "active") : admin_questions_path(bloc: @current_bloc, status: "active")), 
                  class: "px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 #{@status_filter == 'active' ? "bg-white text-[var(--color-primary)] shadow-sm border border-slate-100" : "text-slate-400 hover:text-slate-600"}",
                  data: { turbo_frame: "questions_table", turbo_action: "advance", tab_activation_target: "tab", action: "click->tab-activation#activate" } do %>
        ACtive
      <% end %>
      <%= link_to (@questionnaire ? admin_questionnaire_questions_path(@questionnaire, bloc: @current_bloc, status: "inactive") : admin_questions_path(bloc: @current_bloc, status: "inactive")), 
                  class: "px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 #{@status_filter == 'inactive' ? "bg-white text-[var(--color-primary)] shadow-sm border border-slate-100" : "text-slate-400 hover:text-slate-600"}",
                  data: { turbo_frame: "questions_table", turbo_action: "advance", tab_activation_target: "tab", action: "click->tab-activation#activate" } do %>
        Inactif
      <% end %>
    </div>

    <!-- Bloc Tabs -->
    <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 scrollbar-hide bg-slate-100/50 p-1.5 rounded-2xl border border-slate-100" 
         data-controller="tab-activation"
         data-tab-activation-active-class="bg-white text-[var(--color-primary)] shadow-sm border border-slate-100"
         data-tab-activation-inactive-class="text-slate-400 hover:text-slate-600">
      <% (1..(@questionnaire&.total_blocs || 5)).each do |i| %>
        <%= link_to (@questionnaire ? admin_questionnaire_questions_path(@questionnaire, bloc: i, status: @status_filter) : admin_questions_path(bloc: i, status: @status_filter)), 
                    class: "px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 #{i == @current_bloc ? "bg-white text-[var(--color-primary)] shadow-sm border border-slate-100" : "text-slate-400 hover:text-slate-600"}",
                    data: { turbo_frame: "questions_table", turbo_action: "advance", tab_activation_target: "tab", action: "click->tab-activation#activate" } do %>
          BLOC <%= i %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @current_bloc.present? %>
    <div class="flex items-center gap-2 text-[10px] font-black text-[var(--color-primary)] uppercase tracking-widest bg-[var(--color-primary)]/5 px-4 py-2 rounded-full border border-[var(--color-primary)]/10">
      <%= lucide_icon "filter", class: "w-3 h-3" %>
      Filtré : Bloc <%= @current_bloc %>
    </div>
  <% end %>
</div>

<%= turbo_frame_tag "questions_table" do %>
  <% if @questions.any? %>
    <%= render "shared/table",
      data: { data: { controller: "sortable", sortable_url_value: @questionnaire ? reorder_admin_questionnaire_questions_path(@questionnaire) : reorder_admin_questions_path } },
      columns: [
        { header: "", width: "50px", cell: ->(q){ content_tag(:div, lucide_icon("grip-vertical", class: "w-4 h-4 text-slate-300 cursor-grab active:cursor-grabbing"), data: { sortable_handle: true }) } },
        { header: "Texte de la question", cell: ->(q){ content_tag(:div, q.text&.truncate(100), class: "max-w-md whitespace-normal leading-tight font-medium text-slate-700") } },
        { header: "Type", cell: ->(q){ content_tag(:span, q.kind&.upcase, class: "text-[10px] font-black text-slate-400 tracking-widest") } },
        { header: "Statut", cell: ->(q){ render "shared/badge", text: (q.active? ? "Active" : "Inactive"), color: (q.active? ? :green : :gray) } }
      ],
      rows: @questions,
      pagy: @pagy,
      actions: ->(q){
        capture do %>
          <%= link_to edit_admin_question_path(q), class: "p-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition-colors", data: { turbo_frame: "_top" } do %>
            <%= lucide_icon "edit-3", class: "w-4 h-4" %>
          <% end %>
          <%= button_to admin_question_path(q), method: :delete, data: { turbo_confirm: "Confirmer la suppression ?", turbo_frame: "_top" }, class: "p-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors border-0" do %>
            <%= lucide_icon "trash-2", class: "w-4 h-4" %>
          <% end %>
        <% end
      } %>
  <% else %>
    <%= render "shared/empty_state", 
               icon: "search-x",
               title: "Aucune question trouvée",
               description: @current_bloc ? "Il n'y a pas encore de questions dans le bloc #{@current_bloc}." : "Commencez par ajouter votre première question.",
               action_text: "Ajouter une question",
               action_url: @questionnaire ? new_admin_questionnaire_question_path(@questionnaire) : new_admin_question_path %>
  <% end %>
<% end %>
