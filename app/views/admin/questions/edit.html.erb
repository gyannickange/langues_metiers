<% content_for :page_title, "Modifier la Question" %>

<%= render "shared/page_header", 
    title: "Modifier la Question",
    subtitle: @question.questionnaire ? "Modèle : #{@question.questionnaire.title}" : "Question isolée",
    action_text: "Retour",
    action_url: @question.questionnaire ? admin_questionnaire_questions_path(@question.questionnaire) : admin_questions_path,
    action_icon: "arrow-left",
    action_type: :secondary %>

<%= render "form", question: @question, questionnaire: @question.questionnaire, url: @question.questionnaire ? admin_questionnaire_question_path(@question.questionnaire, @question) : admin_question_path(@question) %>
