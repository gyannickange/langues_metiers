<% content_for :page_title, "Nouvelle Question" %>

<%= render "shared/page_header", 
    title: "Nouvelle Question",
    subtitle: @questionnaire ? "Modèle : #{@questionnaire.title}" : "Question isolée",
    action_text: "Retour",
    action_url: @questionnaire ? admin_questionnaire_questions_path(@questionnaire) : admin_questions_path,
    action_icon: "arrow-left",
    action_type: :secondary %>

<%= render "form", question: @question, questionnaire: @questionnaire, url: @questionnaire ? admin_questionnaire_questions_path(@questionnaire) : admin_questions_path %>
