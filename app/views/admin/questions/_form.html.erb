<div class="glass-card rounded-2xl p-8 shadow-premium animate-premium-in max-w-2xl">
  <%= form_with model: [:admin, question], class: "space-y-6" do |f| %>
    <% if question.errors.any? %>
      <div class="bg-red-50 border border-red-100 p-4 rounded-xl text-sm text-red-700 mb-6 animate-shake">
        <div class="font-bold flex items-center gap-2 mb-1">
          <%= lucide_icon "alert-circle", class: "w-4 h-4" %>
          <%= t("errors.messages.not_saved", count: question.errors.count, resource: "question") %>
        </div>
        <ul class="list-disc list-inside opacity-90">
          <% question.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="space-y-1">
        <%= f.label :bloc, "Bloc (1–5)", class: "text-[10px] font-black uppercase tracking-widest text-slate-400" %>
        <%= f.number_field :bloc, min: 1, max: 5, 
              class: "w-full bg-slate-50 border-0 rounded-xl px-4 py-3 text-sm font-bold focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all font-mono" %>
      </div>
      <div class="space-y-1">
        <%= f.label :position, "Position", class: "text-[10px] font-black uppercase tracking-widest text-slate-400" %>
        <%= f.number_field :position, min: 1, 
              class: "w-full bg-slate-50 border-0 rounded-xl px-4 py-3 text-sm font-bold focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all font-mono" %>
      </div>
      <div class="space-y-1">
        <%= f.label :kind, "Type", class: "text-[10px] font-black uppercase tracking-widest text-slate-400" %>
        <%= f.select :kind, [["Likert", "likert"], ["Choix multiple", "multiple_choice"]], {}, 
              class: "w-full bg-slate-50 border-0 rounded-xl px-4 py-3 text-sm font-bold focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all cursor-pointer" %>
      </div>
    </div>

    <div class="space-y-1">
      <%= f.label :text, "Texte de la question", class: "text-[10px] font-black uppercase tracking-widest text-slate-400" %>
      <%= f.text_area :text, rows: 4, placeholder: "Entrez l'énoncé de la question...",
            class: "w-full bg-slate-50 border-0 rounded-xl px-4 py-3 text-sm font-medium focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all leading-relaxed" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl">
        <%= f.check_box :scored, class: "w-5 h-5 rounded-lg border-slate-300 text-[var(--color-primary)] focus:ring-[var(--color-primary)]/20 cursor-pointer" %>
        <%= f.label :scored, "Question Scorée", class: "text-sm font-bold text-slate-700 cursor-pointer" %>
      </div>
      <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl">
        <%= f.check_box :active, class: "w-5 h-5 rounded-lg border-slate-300 text-[var(--color-primary)] focus:ring-[var(--color-primary)]/20 cursor-pointer" %>
        <%= f.label :active, "Question Active", class: "text-sm font-bold text-slate-700 cursor-pointer" %>
      </div>
    </div>

    <div class="pt-4 flex items-center gap-4">
      <%= f.submit "Enregistrer", class: "bg-[var(--color-primary)] text-white px-8 py-3 rounded-xl font-bold text-sm uppercase tracking-widest hover:opacity-90 transition-all shadow-sm transform hover:translate-y-[-1px] cursor-pointer" %>
      <%= link_to "Annuler", admin_questions_path, class: "text-slate-400 text-xs font-bold uppercase tracking-widest hover:text-slate-600 transition-colors" %>
    </div>
  <% end %>
</div>
