<div class="glass-card rounded-2xl p-8 shadow-premium animate-premium-in max-w-2xl">
  <%= form_with model: [:admin, operator], class: "space-y-6" do |f| %>
    <% if operator.errors.any? %>
      <div class="bg-red-50 border border-red-100 p-4 rounded-xl text-sm text-red-700 mb-6 animate-shake">
        <div class="font-bold flex items-center gap-2 mb-1">
          <%= lucide_icon "alert-circle", class: "w-4 h-4" %>
          <%= t("errors.messages.not_saved", count: operator.errors.count, resource: "opérateur") %>
        </div>
        <ul class="list-disc list-inside opacity-90">
          <% operator.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <%= render partial: "shared/form_field", locals: { form: f, field: :country_code, label: "Code Pays (ex: CI, SN)", type: "text", placeholder: "CI", extra_classes: "font-bold font-mono uppercase" } %>
      <%= render partial: "shared/form_field", locals: { form: f, field: :code, label: "Code Opérateur (Pawapay)", type: "text", placeholder: "MOOV_CI", extra_classes: "font-bold font-mono uppercase" } %>
    </div>

    <%= render partial: "shared/form_field", locals: { form: f, field: :name, label: "Nom de l'Opérateur", type: "text", placeholder: "Ex: Moov Africa" } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :logo_url, label: "URL du Logo", type: "text", placeholder: "https://..." } %>

    <%= render partial: "shared/form_field", locals: { form: f, field: :active, label: "Opérateur Actif", type: "checkbox" } %>

    <div class="pt-4 flex items-center gap-4">
      <%= f.submit "Enregistrer", class: "bg-[var(--color-primary)] text-white px-8 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-all shadow-sm transform hover:translate-y-[-1px] cursor-pointer" %>
      <%= link_to "Annuler", admin_mobile_operators_path, class: "text-slate-400 text-xs font-bold hover:text-slate-600 transition-colors" %>
    </div>
  <% end %>
</div>
