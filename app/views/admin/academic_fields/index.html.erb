<% content_for :page_title, "Filière académiques" %>

<%= render "shared/page_header",
    title: "Filière académiques",
    subtitle: "Gérer des filières académiques",
    action_text: "Nouvelle filière académique",
    action_url: new_admin_academic_field_path,
    action_icon: "plus" %>

<%= render "shared/table",
  columns: [
    { header: "Name",     cell: ->(f){ link_to f.name, admin_academic_field_path(f), class: "text-[var(--color-primary)] font-bold hover:underline" } },
    { header: "Slug",     cell: ->(f){ content_tag(:span, f.slug, class: "text-slate-500 font-mono text-xs") } },
    { header: "Position", cell: ->(f){ content_tag(:span, f.position, class: "text-slate-500") } }
  ],
  rows: @academic_fields,
  pagy: @pagy,
  actions: ->(f){
    capture do %>
      <%= link_to edit_admin_academic_field_path(f), class: "p-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition-colors" do %>
        <%= lucide_icon "edit-3", class: "w-4 h-4" %>
      <% end %>
      <%= button_to admin_academic_field_path(f), method: :delete, data: { turbo_confirm: t("admin.shared.confirm_delete") }, class: "p-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors border-0" do %>
        <%= lucide_icon "trash-2", class: "w-4 h-4" %>
      <% end %>
    <% end
  } %>
