<div class="glass-card rounded-2xl p-8 shadow-premium animate-premium-in max-w-2xl">
  <%= form_with model: [:admin, academic_field], class: "space-y-6" do |form| %>
    <% if academic_field.errors.any? %>
      <div class="bg-red-50 border border-red-100 p-4 rounded-xl text-sm text-red-700 mb-6 animate-shake">
        <div class="font-bold flex items-center gap-2 mb-1">
          <%= lucide_icon :alert_circle, class: "w-4 h-4" %>
          <%= t("errors.messages.not_saved", count: academic_field.errors.count, resource: "academic field") %>
        </div>
        <ul class="list-disc list-inside opacity-90">
          <% academic_field.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render partial: "shared/form_field", locals: { form: form, field: :name, label: "Nom du domaine académique", type: "text" } %>

    <% if academic_field.persisted? %>
      <div class="space-y-1">
        <span class="text-[10px] font-black text-slate-400">Slug</span>
        <p class="mt-1 text-sm font-mono text-slate-600"><%= academic_field.slug %></p>
      </div>
    <% end %>

    <div class="pt-4 flex items-center gap-4">
      <%= form.submit t("Save"), class: "bg-[var(--color-primary)] text-white px-8 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-all shadow-sm transform hover:translate-y-[-1px] cursor-pointer" %>
      <%= link_to t("Cancel"), admin_academic_fields_path, class: "text-slate-400 text-xs font-bold hover:text-slate-600 transition-colors" %>
    </div>
  <% end %>
</div>
