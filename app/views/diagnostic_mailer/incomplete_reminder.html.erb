<p style="color: #4b5563; font-size: 16px; margin: 0 0 15px 0;">Bonjour <%= @user.first_name || @user.email %>,</p>

<% case @delay_type %>
<% when "30m" %>
  <p style="color: #4b5563; font-size: 16px; line-height: 1.6; margin: 0 0 20px 0;">Nous avons remarqué que vous avez commencé un diagnostic d'orientation, mais que vous ne l'avez pas encore terminé. Ne perdez pas votre progression !</p>
<% when "1h" %>
  <p style="color: #4b5563; font-size: 16px; line-height: 1.6; margin: 0 0 20px 0;">Votre diagnostic d'orientation n'attend plus que vous. Terminer cette évaluation est la première étape vers la découverte des métiers qui correspondent vraiment à votre profil.</p>
<% when "1d" %>

  <p style="color: #4b5563; font-size: 16px; line-height: 1.6; margin: 0 0 20px 0;">C'est votre dernier rappel. Ne laissez pas votre diagnostic inachevé ! Prenez quelques minutes dès maintenant pour explorer votre potentiel et découvrir vos résultats personnalisés.</p>
<% end %>

<p style="color: #4b5563; font-size: 16px; line-height: 1.6; margin: 0 0 30px 0;">Cliquez sur le bouton ci-dessous pour reprendre là où vous vous étiez arrêté :</p>

<div style="text-align: center; margin-bottom: 30px;">
  <a href="<%= url_for(controller: 'diagnostics', action: 'assessment', id: @diagnostic.id, only_path: false) %>" 
     style="background-color: #D4AF37; color: #ffffff; padding: 12px 24px; text-decoration: none; border-radius: 8px; font-weight: bold; display: inline-block;">
    Reprendre mon diagnostic
  </a>
</div>
