<% content_for :header do %>
  <%= render 'shared/lp_header' %>
<% end %>

<!-- Problème Section -->
<section class="py-24 bg-white relative">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-8">
          <%= t('home.problem.title') %>
        </h2>

        <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
          <p>
            <%= t('home.problem.description') %>
          </p>

          <div class="bg-gray-50 p-8 rounded-2xl border-l-4 border-primary">
            <h3 class="font-bold text-secondary mb-4 uppercase tracking-wider text-sm"><%= t('home.problem.subtitle') %></h3>

            <ul class="space-y-3">
              <% t('home.problem.items').each do |item| %>
                <li class="flex items-center">
                  <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  <%= item %>
                </li>
              <% end %>
            </ul>

          </div>
          <p class="font-bold text-secondary pt-4 italic">
            "<%= t('home.problem.quote') %>"
          </p>

        </div>
      </div>
      <div class="relative">
        <div class="aspect-square bg-gray-100 rounded-3xl overflow-hidden shadow-2xl rotate-3">
          <%= image_tag "img-1.png", class: "w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" %>
        </div>
        <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-primary/20 rounded-full blur-3xl -z-10"></div>
      </div>
    </div>
  </div>
</section>

<!-- Réalité du Marché Section -->
<section class="py-24 bg-secondary text-white relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-6"><%= t('home.market.title') %></h2>
      <p class="text-xl text-gray-400 font-light"><%= t('home.market.subtitle') %></p>

    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% [
        { title: t('home.market.features.analysis'), icon: "troubleshoot" },
        { title: t('home.market.features.digital'), icon: "devices" },
        { title: t('home.market.features.structured'), icon: "account_tree" },
        { title: t('home.market.features.operational'), icon: "visibility" },
        { title: t('home.market.features.tools'), icon: "terminal" },
        { title: t('home.market.features.data'), icon: "bar_chart" }
      ].each do |item| %>

        <div class="bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/10 transition-all group">
          <span class="material-icons text-primary text-4xl mb-4 group-hover:scale-110 transition-transform"><%= item[:icon] %></span>
          <h3 class="text-xl font-semibold"><%= item[:title] %></h3>
        </div>
      <% end %>
    </div>
    
    <div class="mt-20 text-center max-w-3xl mx-auto">
      <p class="text-lg text-gray-300 italic">
        "<%= t('home.market.quote') %>"
      </p>

    </div>
  </div>
</section>

<!-- Métiers Section -->
<section class="py-24 bg-gray-50 relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-4">
        <%= t('home.metiers.title') %>
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto">Explorez des carrières stratégiques adaptées à votre profil en sciences humaines, lettres et langues.</p>
    </div>

    <!-- Liquid Glass Grid for Careers -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
      <% @random_careers.each do |career| %>
        <div class="group relative bg-white border border-gray-100 p-8 rounded-[2rem] shadow-[0_10px_30px_rgba(0,0,0,0.03)] hover:shadow-[0_20px_50px_rgba(231,200,115,0.15)] hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col justify-between">
          
          <!-- Liquid Hover Effect -->
          <div class="absolute -right-20 -bottom-20 w-48 h-48 bg-gradient-to-br from-primary-100 to-primary-300 rounded-full blur-[50px] opacity-0 group-hover:opacity-40 transition-opacity duration-700 pointer-events-none"></div>

          <div class="relative z-10 mb-8 flex-grow">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-secondary-900 text-primary-500 flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform duration-500 shrink-0">
                 <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <h3 class="text-lg font-black text-secondary-900 uppercase leading-tight group-hover:text-primary-600 transition-colors"><%= career.title %></h3>
            </div>
            
            <p class="text-sm text-gray-500 font-medium leading-relaxed line-clamp-3 group-hover:text-gray-700 transition-colors">
              <%= career.description %>
            </p>
          </div>

          <div class="relative z-10 mt-auto pt-6 border-t border-gray-100 group-hover:border-primary-100 transition-colors">
             <div class="flex items-center space-x-2 mb-2">
                <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Secteurs</p>
             </div>
             <p class="text-xs font-bold text-secondary-800 leading-snug"><%= career.sector %></p>
          </div>
        </div>
      <% end %>
    </div>
    
    <div class="text-center mt-12 relative z-10">
      <p class="text-gray-500 italic mb-6"><%= t('home.metiers.footer') %></p>
      <%= link_to careers_path, class: "btn-premium-primary" do %>
        <span>Découvrir les 20 métiers</span>
        <div class="w-6 h-6 rounded-full bg-secondary-900/10 flex items-center justify-center group-hover:bg-secondary-900/20 transition-colors">
          <svg class="w-3 h-3 text-secondary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Solution Section -->
<section class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="bg-secondary p-12 lg:p-20 rounded-[3rem] text-white overflow-hidden relative">
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl -mr-48 -mt-48"></div>
      
      <div class="relative z-10 grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-block bg-primary text-secondary text-xs font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-widest"><%= t('home.solution.badge') %></span>
          <h2 class="text-4xl md:text-5xl font-bold mb-8"><%= t('home.solution.title') %></h2>
          <p class="text-xl text-gray-300 mb-10 leading-relaxed font-light"><%= t('home.solution.subtitle') %></p>

          
          <div class="grid sm:grid-cols-2 gap-6">
            <% [
                "Score de positionnement visible",
                "Ton profil dominant",
                "Ton potentiel inexploité",
                "Trois trajectoires réalistes",
                "Combinaison stratégique prioritaire",
                "Plan d’action synthétique"
            ].each do |item| %>
              <div class="flex items-center space-x-3">
                <div class="flex-shrink-0 w-6 h-6 bg-primary text-secondary rounded-full flex items-center justify-center">
                  <span class="material-icons text-secondary !text-sm">check</span>
                </div>
                <span class="text-gray-200"><%= item %></span>
              </div>
            <% end %>
          </div>
          
          <div class="mt-12 p-6 bg-white/5 rounded-2xl border border-white/10">
            <p class="text-primary font-semibold flex items-center">
              <span class="material-icons mr-2">description</span>
              <%= t('home.solution.report') %>

            </p>
          </div>
        </div>
        
        <div class="hidden lg:block">
          <div class="bg-white/10 backdrop-blur-md p-8 rounded-3xl border border-white/10 shadow-2xl skew-y-3">
            <div class="h-4 w-1/3 bg-primary/50 rounded-full mb-8"></div>
            <div class="space-y-6">
              <div class="h-10 bg-white/10 rounded-xl"></div>
              <div class="h-10 bg-white/10 rounded-xl"></div>
              <div class="h-10 bg-white/10 rounded-xl"></div>
              <div class="h-32 bg-primary/20 rounded-xl border border-primary/30 flex items-center justify-center">
                <span class="text-primary font-bold text-2xl animate-pulse">RAPPORT GÉNÉRÉ</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How it Works -->
<section class="py-24 bg-white text-secondary">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4"><%= t('home.how_it_works.title') %></h2>

      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
    
    <div class="grid md:grid-cols-3 gap-12 max-w-5xl mx-auto">
      <% [
        { step: "1", title: t('home.how_it_works.steps.step1'), content: t('home.how_it_works.steps.step1_desc') },
        { step: "2", title: t('home.how_it_works.steps.step2'), content: t('home.how_it_works.steps.step2_desc') },
        { step: "3", title: t('home.how_it_works.steps.step3'), content: t('home.how_it_works.steps.step3_desc') }
      ].each do |item| %>

        <div class="text-center group">
          <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-8 border border-gray-100 group-hover:bg-primary group-hover:text-secondary transition-all duration-300 shadow-inner">
            <span class="text-3xl font-bold"><%= item[:step] %></span>
          </div>
          <h3 class="text-2xl font-bold mb-4 group-hover:text-primary transition-colors"><%= item[:title] %></h3>
          <p class="text-gray-500 leading-relaxed"><%= item[:content] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Exemple Restitution -->
<section class="py-24 bg-gray-50">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto bg-white rounded-[2rem] shadow-2xl p-10 lg:p-16 border border-gray-200">
      <div class="flex justify-between items-start mb-12 border-b border-gray-100 pb-8">
        <div>
          <h2 class="text-2xl font-bold text-secondary uppercase tracking-tighter">Exemple de Restitution</h2>
          <p class="text-gray-400 text-sm">Aperçu du rapport final</p>
        </div>
        <div class="text-right">
          <div class="text-4xl font-black text-primary">72<span class="text-lg text-gray-300">/100</span></div>
          <div class="text-xs font-bold text-secondary-400">SCORE GLOBAL</div>
        </div>
      </div>
      
      <div class="space-y-10">
        <div class="flex flex-col sm:flex-row justify-between gap-6">
          <div class="flex-1">
            <h3 class="text-sm font-bold text-gray-400 uppercase mb-2">Profil dominant</h3>
            <div class="text-xl font-bold text-secondary">Stratège analytique digital</div>
          </div>
          <div class="flex-1">
            <h3 class="text-sm font-bold text-gray-400 uppercase mb-2">Potentiel inexploité</h3>
            <div class="text-xl font-bold text-green-600">Élevé</div>
          </div>
          <div class="flex-1">
            <h3 class="text-sm font-bold text-gray-400 uppercase mb-2">Risque d’invisibilité</h3>
            <div class="text-xl font-bold text-yellow-600">Modéré</div>
          </div>
        </div>
        
        <div class="bg-secondary rounded-2xl p-8 text-white">
          <h3 class="text-primary font-bold mb-6 flex items-center text-lg">
            <span class="material-icons mr-2">trending_up</span>
            Trajectoires recommandées
          </h3>
          <ul class="space-y-4 font-light text-lg">
            <li class="flex items-center">
              <span class="w-1.5 h-1.5 bg-primary rounded-full mr-3"></span>
              Chargé d’études junior
            </li>
            <li class="flex items-center">
              <span class="w-1.5 h-1.5 bg-primary rounded-full mr-3"></span>
              Consultant data ONG
            </li>
            <li class="flex items-center">
              <span class="w-1.5 h-1.5 bg-primary rounded-full mr-3"></span>
              Assistant transformation digitale
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Public Cible Section -->
<section class="py-24 bg-white text-secondary">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row gap-16 items-center">
      <div class="lg:w-1/2">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 leading-tight"><%= t('home.target.title') %></h2>

        <p class="text-xl text-gray-500 mb-10 leading-relaxed font-light">
          <%= t('home.target.subtitle') %>
        </p>

        <div class="grid sm:grid-cols-2 gap-8">
          <% [
            { icon: "school", title: "Étudiants", desc: "En fin de cycle universitaire" },
            { icon: "work_off", title: "Jeunes diplômés", desc: "Actuellement sans emploi" },
            { icon: "trending_up", title: "Professionnels", desc: "Souhaitant évoluer vers le digital" },
            { icon: "history_edu", title: "Profils SHS", desc: "Lettres, sciences humaines, droit" }
          ].each do |item| %>
            <div class="flex flex-col">
              <span class="material-icons text-primary !text-4xl mb-4"><%= item[:icon] %></span>
              <h4 class="font-bold text-xl mb-2"><%= item[:title] %></h4>
              <p class="text-gray-500"><%= item[:desc] %></p>
            </div>
          <% end %>
        </div>
      </div>
      <div class="lg:w-1/2 bg-gray-50 p-4 rounded-[2.5rem]">
        <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?auto=format&fit=crop&w=800&q=80" alt="Audience" class="rounded-[2rem] shadow-xl grayscale contrast-125">
      </div>
    </div>
  </div>
</section>

<!-- Tarification -->
<section class="py-24 bg-secondary overflow-hidden relative">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4 italic"><%= t('home.pricing.title') %></h2>

      <p class="text-primary tracking-widest uppercase font-bold text-sm"><%= t('home.pricing.subtitle') %></p>

    </div>
    
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Diagnostic Essentiel -->
      <div class="bg-white rounded-3xl p-10 shadow-2xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:scale-110 transition-transform">
          <span class="material-icons !text-9xl">bookmark</span>
        </div>
        <h3 class="text-2xl font-bold text-secondary mb-2"><%= t('home.pricing.essential') %></h3>

        <div class="text-4xl font-black text-secondary mb-6 flex items-baseline">
          <%= Diagnostic.formatted_price.gsub(" F CFA", "") %> <span class="text-sm ml-1 font-bold text-gray-400">F CFA</span>
        </div>
        <div class="h-px bg-gray-100 mb-8 w-full"></div>
        <ul class="space-y-4 text-gray-600 mb-10">
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> Questionnaire complet</li>
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> Rapport de score immédiat</li>
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> Profil dominant identifié</li>
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> 3 trajectoires conseillées</li>
        </ul>
        <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "btn-premium-secondary group w-full justify-center py-4 rounded-xl" do %>
          <span><%= t('home.pricing.order') %></span>
          <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-colors ml-2">
            <svg class="w-3 h-3 text-primary-500 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </div>
        <% end %>
      </div>

      <!-- Roadmap Premium -->
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-10 border border-white/20 text-white relative overflow-hidden group">
        <div class="absolute -top-4 -right-4 bg-primary text-secondary text-[10px] font-black uppercase px-12 py-6 rotate-45 shadow-lg">PREMIUM</div>
        <h3 class="text-2xl font-bold text-primary mb-2"><%= t('home.pricing.premium') %></h3>

        <div class="text-4xl font-black mb-6 flex items-baseline">
          Contactez-nous
        </div>
        <div class="h-px bg-white/10 mb-8 w-full"></div>
        <ul class="space-y-4 text-gray-300 mb-10">
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Tout du Diagnostic Essentiel</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Plan détaillé 6-12 mois</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Compétences à développer</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Outil digitaux à maîtriser</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Étapes concrètes de mise en œuvre</li>
        </ul>
        <a href="mailto:contact@languesmetiers.com" class="btn-premium-primary group w-full justify-center py-4 rounded-xl">
          <span>Prendre RDV</span>
          <div class="w-6 h-6 rounded-full bg-secondary-900/10 flex items-center justify-center group-hover:bg-secondary-900/20 transition-colors ml-2">
            <svg class="w-3 h-3 text-secondary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA Section -->
<section class="py-24 bg-white relative">
  <div class="container mx-auto px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-5xl font-bold text-secondary mb-10 leading-tight">
        Une trajectoire professionnelle se structure. <br/>Elle ne s’improvise pas.
      </h2>
      <p class="text-xl text-gray-500 mb-12 font-light"><%= t('home.final.subtitle') %></p>

      
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
        <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "btn-premium-primary px-12 py-6 text-xl justify-center relative overflow-hidden" do %>
          <div class="absolute inset-0 w-full h-full bg-white/20 -skew-x-12 translate-x-full group-hover:-translate-x-full transition-transform duration-700"></div>
          <span class="relative z-10"><%= t('home.final.cta') %></span>

        <% end %>
      </div>
      
      <div class="mt-12 flex items-center justify-center space-x-8 opacity-50 grayscale hover:grayscale-0 transition-all">
        <span class="font-bold text-secondary text-sm tracking-widest uppercase italic">Rapport Instantané</span>
      </div>
    </div>
  </div>
</section>
