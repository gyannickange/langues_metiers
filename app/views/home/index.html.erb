<% content_for :header do %>
  <%= render 'shared/lp_header' %>
<% end %>

<%# ═══════════════════════════════════════════════════════════ %>
<%# 01 — PROBLÈME                                              %>
<%# ═══════════════════════════════════════════════════════════ %>
<section class="py-16 md:py-24 bg-[#f7f3ec] relative overflow-hidden">

  <div class="container mx-auto px-6 relative z-10">
    <div data-home-motion-target="group" class="grid md:grid-cols-2 gap-12 md:gap-16 lg:gap-20 items-center">

      <div data-motion-item style="--motion-index: 0">
        <h2 class="lp-section-title lg:text-5xl mb-8">
          <%= t('home.problem.title') %>
        </h2>

        <div class="space-y-4 text-gray-600 text-lg leading-relaxed mb-8">
          <% Array(t('home.problem.description')).each do |paragraph| %>
            <p><%= paragraph %></p>
          <% end %>
        </div>

        <div class="border-l-2 border-primary pl-7 mb-10">
          <h3 class="text-xs font-bold text-secondary/50 uppercase tracking-wide mb-4"><%= t('home.problem.subtitle') %></h3>
          <ul class="space-y-3">
            <% t('home.problem.items').each do |item| %>
              <li class="flex items-start gap-3 text-gray-500 text-sm">
                <svg class="w-4 h-4 text-red-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                <%= item %>
              </li>
            <% end %>
          </ul>
        </div>

        <blockquote class="text-lg sm:text-xl italic text-secondary/70 leading-relaxed">
          "<%= t('home.problem.quote') %>"
        </blockquote>
      </div>

      <div data-motion-item style="--motion-index: 1" class="relative">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-[0_30px_80px_rgba(31,75,67,0.12)]">
          <%= image_tag "img-1.webp", alt: "Jeune diplômé réfléchissant à son positionnement professionnel", class: "w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000" %>
        </div>
        <div class="absolute -bottom-5 -left-5 w-24 h-24 rounded-full border-2 border-primary/20 bg-[#f7f3ec]"></div>
        <div class="absolute -top-4 -right-4 w-10 h-10 rounded-full bg-primary/12"></div>
      </div>

    </div>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 02 — MARCHÉ                                                %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="market" class="py-16 md:py-24 bg-secondary text-white relative overflow-hidden">

  <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
    style="background-image: radial-gradient(circle, #e7c873 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mb-20">
      <h2 class="text-balance text-3xl font-bold leading-tight md:text-5xl mb-5">
        <%= t('home.market.title') %>
      </h2>
      <p class="text-white/75 text-lg md:text-xl leading-relaxed"><%= t('home.market.subtitle') %></p>
    </div>

    <div data-home-motion-target="group" class="grid lg:grid-cols-3 gap-px bg-white/[0.08] rounded-2xl overflow-hidden">
      <% [
        { num: "01", title: t('home.market.features.analysis'), icon: "troubleshoot", desc: t('home.market.features.digital') },
        { num: "02", title: t('home.market.features.structured'), icon: "account_tree", desc: t('home.market.features.operational') },
        { num: "03", title: t('home.market.features.tools'), icon: "terminal", desc: t('home.market.features.data') }
      ].each_with_index do |item, i| %>
        <div data-motion-item style="--motion-index: <%= i %>" class="bg-secondary p-10 hover:bg-white/[0.05] transition-colors duration-300 group">
          <div class="text-[5rem] font-bold text-white/[0.04] leading-none mb-5 group-hover:text-primary/10 transition-colors duration-300"><%= item[:num] %></div>
          <span class="material-icons text-primary !text-3xl mb-5 block"><%= item[:icon] %></span>
          <h3 class="text-base font-bold text-white mb-3 leading-snug"><%= item[:title] %></h3>
          <p class="text-white/35 text-sm leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 03 — MÉTIERS                                               %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="careers" class="py-16 md:py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-6">

    <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-16 gap-6">
      <h2 class="lp-section-title lg:text-5xl">
        <%= t('home.metiers.title') %>
      </h2>
      <%= link_to careers_path, class: "lp-action-primary shrink-0 self-end" do %>
        <span>Voir plus</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      <% end %>
    </div>

    <div data-home-motion-target="group" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @random_careers.each_with_index do |career, index| %>
        <%= render "shared/career_card", career: career, index: index, heading_tag: :h3 %>
      <% end %>
    </div>

    <% if @random_careers.empty? %>
      <p class="text-center text-gray-400 text-sm py-10"><%= t('home.metiers.empty') %></p>
    <% end %>

    <p class="text-center text-gray-400 text-sm italic mt-10"><%= t('home.metiers.footer') %></p>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 04 — SOLUTION                                              %>
<%# ═══════════════════════════════════════════════════════════ %>
<section class="py-16 md:py-24 bg-[#0d2420] relative overflow-hidden">

  <div class="absolute right-0 top-0 w-[420px] h-[420px] bg-primary/3 rounded-full blur-[120px] pointer-events-none -mr-40 -mt-40"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div data-home-motion-target="group" class="grid md:grid-cols-2 gap-12 md:gap-16 lg:gap-20 items-center">

      <%# Left: solution description %>
      <div data-motion-item style="--motion-index: 0">
        <span class="inline-block bg-primary text-secondary text-[0.62rem] font-black px-4 py-1.5 rounded-full mb-6 uppercase tracking-[0.18em]"><%= t('home.solution.badge') %></span>
        <p class="text-white/75 text-lg mb-10 leading-relaxed"><%= t('home.solution.subtitle') %></p>

        <div class="grid sm:grid-cols-2 gap-3.5 mb-10">
          <% [
            "Ton profil dominant",
            "Ton potentiel inexploité",
            "Trois trajectoires réalistes",
            "Combinaison stratégique prioritaire",
            "Plan d'action synthétique"
          ].each do |item| %>
            <div class="flex items-center gap-3">
              <span class="w-5 h-5 rounded-full bg-primary/15 border border-primary/30 flex items-center justify-center shrink-0">
                <span class="material-icons text-primary !text-xs">check</span>
              </span>
              <span class="text-white/55 text-sm"><%= item %></span>
            </div>
          <% end %>
        </div>

        <div class="p-4 bg-white/[0.05] rounded-xl border border-white/[0.08] flex items-center gap-3">
          <span class="material-icons text-primary !text-base">description</span>
          <span class="text-primary text-sm font-medium"><%= t('home.solution.report') %></span>
        </div>
      </div>

      <%# Right: realistic report preview %>
      <div data-motion-item style="--motion-index: 1">
        <div class="bg-white rounded-2xl shadow-[0_24px_70px_rgba(0,0,0,0.3)] overflow-hidden">

          <%# Report header bar %>
          <div class="bg-secondary px-7 py-5 flex justify-between items-center">
            <div>
              <div class="text-primary text-[0.58rem] font-bold tracking-[0.2em] uppercase">Insertrix · Rapport de diagnostic</div>
              <div class="text-white/35 text-xs mt-0.5">Profil · Sciences Humaines</div>
            </div>
            <div class="text-right">
              <div class="text-5xl font-bold text-primary leading-none">72</div>
              <div class="text-white/25 text-[0.52rem] uppercase tracking-wider">/100 Score global</div>
            </div>
          </div>

          <%# Report body %>
          <div class="p-7 space-y-5">

            <%# Summary chips %>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2.5">
              <div class="bg-emerald-50 rounded-xl p-3 text-center">
                <div class="text-[0.52rem] font-bold text-gray-400 uppercase tracking-wider mb-1">Profil</div>
                <div class="text-[0.7rem] font-black text-secondary leading-tight">Stratège analytique</div>
              </div>
              <div class="bg-amber-50 rounded-xl p-3 text-center">
                <div class="text-[0.52rem] font-bold text-gray-400 uppercase tracking-wider mb-1">Potentiel</div>
                <div class="text-[0.7rem] font-black text-emerald-700">Élevé</div>
              </div>
              <div class="bg-orange-50 rounded-xl p-3 text-center">
                <div class="text-[0.52rem] font-bold text-gray-400 uppercase tracking-wider mb-1">Visibilité</div>
                <div class="text-[0.7rem] font-black text-orange-600">Modérée</div>
              </div>
            </div>

            <%# Skill bars %>
            <div class="space-y-2.5">
              <div class="text-[0.58rem] font-black text-gray-400 uppercase tracking-wider mb-1">Compétences clés</div>
              <% [
                { label: "Analyse & Synthèse", pct: 88 },
                { label: "Communication digitale", pct: 72 },
                { label: "Outils data", pct: 55 },
                { label: "Gestion de projet", pct: 64 }
              ].each do |skill| %>
                <div>
                  <div class="flex justify-between text-[0.6rem] mb-1">
                    <span class="text-gray-400 font-medium"><%= skill[:label] %></span>
                    <span class="font-bold text-secondary"><%= skill[:pct] %>%</span>
                  </div>
                  <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-primary-400 to-primary rounded-full" style="width: <%= skill[:pct] %>%"></div>
                  </div>
                </div>
              <% end %>
            </div>

            <%# Trajectories %>
            <div class="bg-secondary rounded-xl p-5">
              <div class="text-[0.58rem] font-black text-primary uppercase tracking-wider mb-3.5">Trajectoires recommandées</div>
              <div class="space-y-2.5">
                <% ["Chargé d'études junior", "Consultant data ONG", "Chargé de com. digitale"].each do |traj| %>
                  <div class="flex items-center gap-2.5 text-white/55 text-xs">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary/70 shrink-0"></span>
                    <%= traj %>
                  </div>
                <% end %>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 05 — MÉTHODE                                               %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="process" class="py-16 md:py-24 bg-[#f7f3ec]">
  <div class="container mx-auto px-6">

    <div class="text-center mb-20">
      <h2 class="lp-section-title lg:text-5xl mx-auto">
        <%= t('home.how_it_works.title') %>
      </h2>
      <div class="w-14 h-[2px] bg-primary mx-auto mt-6"></div>
    </div>

    <div data-home-motion-target="group" class="grid md:grid-cols-3 gap-12 max-w-5xl mx-auto relative">
      <%# Connecting line — desktop %>
      <div class="hidden md:block absolute top-[2.9rem] left-[calc(1/6*100%+3rem)] right-[calc(1/6*100%+3rem)] h-px bg-primary/15"></div>

      <% [
        { step: "01", title: t('home.how_it_works.steps.step1'), desc: t('home.how_it_works.steps.step1_desc') },
        { step: "02", title: t('home.how_it_works.steps.step2'), desc: t('home.how_it_works.steps.step2_desc') },
        { step: "03", title: t('home.how_it_works.steps.step3'), desc: t('home.how_it_works.steps.step3_desc') }
      ].each_with_index do |item, i| %>
        <div data-motion-item style="--motion-index: <%= i %>" class="text-center group relative">
          <div class="w-24 h-24 rounded-full border-2 border-primary/20 bg-[#f7f3ec] flex items-center justify-center mx-auto mb-8 group-hover:bg-primary group-hover:border-primary transition-all duration-400 relative z-10">
            <span class="text-3xl font-bold text-secondary/35 group-hover:text-secondary transition-colors duration-300"><%= item[:step] %></span>
          </div>
          <h3 class="text-2xl font-bold text-secondary mb-4 group-hover:text-primary transition-colors duration-300"><%= item[:title] %></h3>
          <p class="text-gray-400 text-sm leading-relaxed max-w-xs mx-auto"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>

  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 06 — EXEMPLE DE RESTITUTION                                %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="report" class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-6">

    <div class="text-center mb-16">
      <h2 class="lp-section-title lg:text-4xl mx-auto">Exemple de Restitution</h2>
      <p class="lp-section-copy text-sm mt-3">Aperçu du rapport final généré</p>
    </div>

    <div data-home-motion-target="group">
      <div data-motion-item class="max-w-3xl mx-auto bg-white rounded-3xl shadow-[0_20px_80px_rgba(31,75,67,0.07)] border border-gray-100 overflow-hidden">

        <%# Header %>
        <div class="bg-secondary px-10 py-7 flex justify-between items-center">
          <div>
            <h2 class="text-sm font-black text-white uppercase tracking-tight">Rapport de Diagnostic · Insertrix</h2>
            <p class="text-white/35 text-xs mt-0.5">Sciences Humaines · Lettres &amp; Langues</p>
          </div>
          <div class="text-right">
            <div class="leading-none">
              <span class="text-5xl font-bold text-primary">72</span><span class="text-xl text-white/20">/100</span>
            </div>
            <div class="text-[0.52rem] font-bold text-white/25 uppercase tracking-wider mt-1">Score Global</div>
          </div>
        </div>

        <div class="p-10 space-y-8">
          <%# Summary row %>
          <div class="flex flex-col sm:flex-row gap-5">
            <div class="flex-1 p-5 bg-[#f7f3ec] rounded-2xl">
              <div class="text-[0.58rem] font-black text-gray-400 uppercase mb-2">Profil dominant</div>
              <div class="font-black text-secondary">Stratège analytique digital</div>
            </div>
            <div class="flex-1 p-5 bg-emerald-50 rounded-2xl">
              <div class="text-[0.58rem] font-black text-gray-400 uppercase mb-2">Potentiel inexploité</div>
              <div class="font-black text-emerald-700">Élevé</div>
            </div>
            <div class="flex-1 p-5 bg-amber-50 rounded-2xl">
              <div class="text-[0.58rem] font-black text-gray-400 uppercase mb-2">Risque d'invisibilité</div>
              <div class="font-black text-amber-700">Modéré</div>
            </div>
          </div>

          <%# Trajectories grid %>
          <div class="bg-secondary rounded-2xl p-8 text-white">
            <div class="flex items-center gap-2 mb-6">
              <span class="material-icons text-primary !text-lg">trending_up</span>
              <h3 class="text-primary font-bold text-[0.7rem] uppercase tracking-[0.2em]">Trajectoires recommandées</h3>
            </div>
            <div class="grid sm:grid-cols-3 gap-5">
              <% ["Chargé d'études junior", "Consultant data ONG", "Assistant transformation digitale"].each_with_index do |traj, i| %>
                <div class="flex items-start gap-3">
                  <span class="text-3xl font-bold text-primary/15 leading-none mt-0.5">0<%= i+1 %></span>
                  <span class="text-white/60 text-sm font-medium leading-snug"><%= traj %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 07 — PUBLIC CIBLE                                          %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="public" class="py-16 md:py-24 bg-secondary text-white relative overflow-hidden">

  <div class="absolute inset-0 pointer-events-none opacity-[0.035]"
    style="background-image: radial-gradient(circle at 65% 35%, #e7c873 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div data-home-motion-target="group" class="grid md:grid-cols-2 gap-12 md:gap-16 lg:gap-20 items-center">

      <div data-motion-item style="--motion-index: 0">
        <h2 class="text-balance text-3xl font-bold leading-tight md:text-5xl mb-6">
          <%= t('home.target.title') %>
        </h2>
        <p class="text-white/75 text-lg md:text-xl mb-12 leading-relaxed">
          <%= t('home.target.subtitle') %>
        </p>

        <div class="grid sm:grid-cols-2 gap-8">
          <% [
            { icon: "school", title: "Étudiants", desc: "En fin de cycle universitaire" },
            { icon: "work_off", title: "Jeunes diplômés", desc: "Actuellement sans emploi" },
            { icon: "trending_up", title: "Professionnels", desc: "Souhaitant évoluer vers le digital" },
            { icon: "history_edu", title: "Profils SHS", desc: "Lettres, sciences humaines, droit" }
          ].each do |item| %>
            <div class="flex items-start gap-4 group">
              <span class="material-icons text-primary !text-2xl mt-0.5 group-hover:scale-105 transition-transform duration-300"><%= item[:icon] %></span>
              <div>
                <h4 class="font-bold text-white mb-1"><%= item[:title] %></h4>
                <p class="text-white/35 text-sm"><%= item[:desc] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div data-motion-item style="--motion-index: 1" class="rounded-3xl overflow-hidden shadow-[0_30px_80px_rgba(0,0,0,0.3)]">
        <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?auto=format&fit=crop&w=800&q=80"
          alt="Notre audience"
          loading="lazy"
          class="w-full h-80 sm:h-[420px] md:h-[500px] object-cover grayscale contrast-125 hover:grayscale-0 transition-all duration-1000">
      </div>

    </div>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 08 — TARIFICATION                                          %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="pricing" class="py-16 md:py-24 bg-[#f7f3ec] relative overflow-hidden">
  <div class="container mx-auto px-6">

    <div class="text-center mb-16">
      <h2 class="lp-section-title lg:text-4xl mx-auto italic mb-4">
        <%= t('home.pricing.title') %>
      </h2>
      <p class="text-primary font-bold text-xs tracking-wide uppercase"><%= t('home.pricing.subtitle') %></p>
    </div>

    <div data-home-motion-target="group" class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">

      <%# Diagnostic Essentiel %>
      <div data-motion-item style="--motion-index: 0" class="bg-white rounded-3xl p-10 border border-gray-100 hover:border-primary/30 transition-all duration-300 hover:shadow-[0_20px_60px_rgba(231,200,115,0.12)] group">
        <h3 class="text-2xl font-bold text-secondary mb-2"><%= t('home.pricing.essential') %></h3>
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-8 mt-4" aria-label="Prix promotionnel : 2 000 francs CFA, maintenant gratuit">
          <span class="text-xl font-bold text-gray-500 line-through decoration-2" aria-hidden="true"><%= Diagnostic.formatted_standard_price %></span>
          <span class="text-5xl font-bold text-secondary leading-none" aria-hidden="true"><%= Diagnostic.formatted_amount %></span>
          <span class="text-sm font-bold text-gray-500" aria-hidden="true">F CFA</span>
          <span class="basis-full text-sm font-bold text-emerald-700">Gratuit pendant la phase de test</span>
        </div>
        <div class="h-px bg-gray-100 mb-8"></div>
        <ul class="space-y-3.5 mb-10">
          <% ["Évaluation complète", "Rapport de score immédiat", "Profil dominant identifié", "3 trajectoires conseillées"].each do |item| %>
            <li class="flex items-center gap-3 text-gray-500 text-sm">
              <span class="material-icons text-emerald-500 !text-[1rem]">check_circle</span>
              <%= item %>
            </li>
          <% end %>
        </ul>
        <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-secondary w-full sm:w-auto justify-center" do %>
          <span><%= t('home.pricing.order') %></span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        <% end %>
      </div>

      <%# Roadmap Premium %>
      <div data-motion-item style="--motion-index: 1" class="bg-secondary rounded-3xl p-10 text-white relative overflow-hidden">
        <div class="absolute top-6 right-6 bg-primary text-secondary text-[0.58rem] font-black px-3 py-1.5 rounded-full uppercase tracking-[0.18em]">Premium</div>
        <h3 class="text-2xl font-bold text-primary mb-2"><%= t('home.pricing.premium') %></h3>
        <div class="text-4xl font-bold text-white mb-8 mt-4">Sur devis</div>
        <div class="h-px bg-white/10 mb-8"></div>
        <ul class="space-y-3.5 mb-10">
          <% [
            "Tout du Diagnostic Essentiel",
            "Plan détaillé 6-12 mois",
            "Compétences à développer",
            "Outils digitaux à maîtriser",
            "Étapes concrètes de mise en œuvre"
          ].each do |item| %>
            <li class="flex items-center gap-3 text-white/55 text-sm">
              <span class="material-icons text-primary !text-[1rem]">auto_awesome</span>
              <%= item %>
            </li>
          <% end %>
        </ul>
        <a href="mailto:contact@languesmetiers.com" class="lp-action-primary w-full sm:w-auto justify-center">
          <span>Prendre RDV</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>


<%# ═══════════════════════════════════════════════════════════ %>
<%# 09 — CTA FINAL                                             %>
<%# ═══════════════════════════════════════════════════════════ %>
<section id="cta" class="py-32 bg-[#0d2420] text-white relative overflow-hidden">

  <div class="absolute inset-0 pointer-events-none opacity-[0.025]"
    style="background-image: linear-gradient(#e7c873 1px, transparent 1px), linear-gradient(90deg, #e7c873 1px, transparent 1px); background-size: 80px 80px;"></div>
  <div class="absolute left-0 top-0 h-full w-[2px] bg-gradient-to-b from-primary/45 via-primary/15 to-transparent"></div>

  <div class="container mx-auto px-6 relative z-10 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-balance text-3xl font-bold leading-tight text-white sm:text-4xl md:text-5xl lg:text-6xl mb-8">
        Une trajectoire <em class="text-primary italic">se structure.</em>
        Elle ne s'improvise pas.
      </h2>

      <p class="text-white/75 text-lg md:text-xl mb-14 max-w-2xl mx-auto leading-relaxed">
        <%= t('home.final.subtitle') %>
      </p>

      <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-primary py-5 px-14 text-base" do %>
        <%= t('home.final.cta') %>
      <% end %>

      <div class="mt-10 flex items-center justify-center gap-6 text-white/35 text-xs tracking-wide uppercase">
        <span>Rapport instantané</span>
        <span class="w-1 h-1 rounded-full bg-white/25"></span>
        <span>30 minutes</span>
        <span class="w-1 h-1 rounded-full bg-white/25"></span>
        <span>100% personnalisé</span>
      </div>
    </div>
  </div>
</section>
