<% content_for :header do %>
  <%= render 'shared/lp_header' %>
<% end %>

<!-- Problème Section -->
<section id="problem" class="relative scroll-mt-8 bg-white py-16 md:py-24">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="lp-section-title mb-8">
          <%= t('home.problem.title') %>
        </h2>

        <div class="lp-section-copy max-w-[70ch] space-y-6 text-lg">
          <% t('home.problem.description').each do |paragraph| %>
            <p><%= paragraph %></p>
          <% end %>

          <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5 sm:p-8">
            <h3 class="mb-4 text-sm font-semibold text-secondary"><%= t('home.problem.subtitle') %></h3>

            <ul class="space-y-3">
              <% t('home.problem.items').each do |item| %>
                <li class="flex items-center">
                  <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  <%= item %>
                </li>
              <% end %>
            </ul>

          </div>
          <p class="font-bold text-secondary pt-4 italic">
            "<%= t('home.problem.quote') %>"
          </p>

        </div>
      </div>
      <div class="relative">
        <div class="aspect-square overflow-hidden rounded-2xl border border-gray-200 bg-gray-100">
          <%= image_tag "img-1.png", alt: "Jeune diplômée réfléchissant à ses prochaines étapes professionnelles", loading: "lazy", class: "h-full w-full object-cover" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Réalité du Marché Section -->
<section id="market" class="relative scroll-mt-8 overflow-hidden bg-secondary py-16 text-white md:py-24">
  <div class="container relative z-10 mx-auto px-4 sm:px-6">
    <div class="mb-10 text-center md:mb-16">
      <h2 class="mb-6 text-balance text-3xl font-bold leading-tight md:text-5xl"><%= t('home.market.title') %></h2>
      <p class="mx-auto max-w-3xl text-pretty text-xl text-white/75"><%= t('home.market.subtitle') %></p>

    </div>
    
    <div data-home-motion-target="group" class="grid gap-4 sm:gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      <% [
        { title: t('home.market.features.analysis'), icon: "troubleshoot" },
        { title: t('home.market.features.digital'), icon: "devices" },
        { title: t('home.market.features.structured'), icon: "account_tree" },
        { title: t('home.market.features.operational'), icon: "visibility" },
        { title: t('home.market.features.tools'), icon: "terminal" },
        { title: t('home.market.features.data'), icon: "bar_chart" }
      ].each_with_index do |item, index| %>

        <div data-motion-item style="--motion-index: <%= index %>" class="rounded-2xl border border-white/15 bg-white/5 p-5 sm:p-8">
          <span class="material-icons mb-4 text-3xl text-primary"><%= item[:icon] %></span>
          <h3 class="text-xl font-semibold"><%= item[:title] %></h3>
        </div>
      <% end %>
    </div>
    
  </div>
</section>

<!-- Métiers Section -->
<section id="careers" class="relative scroll-mt-8 overflow-hidden bg-gray-50 py-16 md:py-24">
  <div class="container relative z-10 mx-auto px-4 sm:px-6">
    <div class="mb-10 text-center md:mb-16">
      <h2 class="lp-section-title mb-4">
        <%= t('home.metiers.title') %>
      </h2>
      <p class="lp-section-copy mx-auto max-w-2xl">Explorez des carrières stratégiques adaptées à votre profil en sciences humaines, lettres et langues.</p>
    </div>

    <div data-home-motion-target="group" class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-8 lg:grid-cols-3 lg:gap-10">
      <% @random_careers.each_with_index do |career, index| %>
        <%= render "shared/career_card", career: career, index: index, heading_tag: :h3 %>
      <% end %>
    </div>
    
    <div class="text-center mt-12 relative z-10">
      <p class="text-gray-500 italic mb-6"><%= t('home.metiers.footer') %></p>
      <%= link_to careers_path, class: "lp-action-primary min-h-12 w-full sm:w-auto" do %>
        <span>Découvrir les 20 métiers</span>
        <svg class="h-4 w-4 text-secondary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      <% end %>
    </div>
  </div>
</section>

<!-- Solution Section -->
<section id="solution" class="scroll-mt-8 bg-white py-16 md:py-24">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="rounded-3xl bg-secondary p-6 text-white sm:p-12 lg:p-20">
      <div class="max-w-4xl">
        <div>
          <span class="mb-6 inline-block rounded-lg bg-primary px-3 py-1.5 text-sm font-semibold text-secondary"><%= t('home.solution.badge') %></span>
          <p class="text-xl text-gray-300 mb-10 leading-relaxed font-light"><%= t('home.solution.subtitle') %></p>

          
          <div data-home-motion-target="group" class="grid gap-6 sm:grid-cols-2">
            <% [
                "Ton profil dominant",
                "Ton potentiel inexploité",
                "Trois trajectoires réalistes",
                "Combinaison stratégique prioritaire",
                "Plan d’action synthétique"
            ].each_with_index do |item, index| %>
              <div data-motion-item style="--motion-index: <%= index %>" class="flex items-center space-x-3">
                <div class="flex-shrink-0 w-6 h-6 bg-primary text-secondary rounded-full flex items-center justify-center">
                  <span class="material-icons text-secondary !text-sm">check</span>
                </div>
                <span class="text-gray-200"><%= item %></span>
              </div>
            <% end %>
          </div>
          
          <div class="mt-12 p-6 bg-white/5 rounded-2xl border border-white/10">
            <p class="text-primary font-semibold flex items-center">
              <span class="material-icons mr-2">description</span>
              <%= t('home.solution.report') %>

            </p>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>

<!-- How it Works -->
<section id="process" class="scroll-mt-8 bg-white py-16 text-secondary md:py-24">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="mb-10 text-center md:mb-16">
      <h2 class="lp-section-title mb-4"><%= t('home.how_it_works.title') %></h2>

    </div>
    
    <div data-home-motion-target="group" class="mx-auto grid max-w-5xl gap-10 md:grid-cols-3 md:gap-12">
      <% [
        { step: "1", title: t('home.how_it_works.steps.step1'), content: t('home.how_it_works.steps.step1_desc') },
        { step: "2", title: t('home.how_it_works.steps.step2'), content: t('home.how_it_works.steps.step2_desc') },
        { step: "3", title: t('home.how_it_works.steps.step3'), content: t('home.how_it_works.steps.step3_desc') }
      ].each_with_index do |item, index| %>

        <div data-motion-item style="--motion-index: <%= index %>" class="text-center">
          <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-xl border border-secondary-100 bg-secondary-50">
            <span class="text-xl font-semibold text-secondary"><%= item[:step] %></span>
          </div>
          <h3 class="mb-4 text-2xl font-semibold"><%= item[:title] %></h3>
          <p class="lp-section-copy"><%= item[:content] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Exemple Restitution -->
<section id="report" class="scroll-mt-8 bg-gray-50 py-16 md:py-24">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="mx-auto max-w-3xl rounded-3xl border border-gray-200 bg-white p-6 shadow-sm sm:p-10 lg:p-16">
      <div class="mb-8 flex flex-col gap-5 border-b border-gray-100 pb-6 sm:mb-12 sm:flex-row sm:items-start sm:justify-between sm:pb-8">
        <div>
          <h2 class="text-2xl font-semibold text-secondary">Exemple de restitution</h2>
          <p class="text-sm text-gray-600">Aperçu du rapport final</p>
        </div>
        <div class="sm:text-right">
          <div class="text-4xl font-black text-primary">72<span class="text-lg text-gray-300">/100</span></div>
          <div class="text-sm font-semibold text-secondary-700">Score global</div>
        </div>
      </div>
      
      <div class="space-y-10">
        <div class="flex flex-col sm:flex-row justify-between gap-6">
          <div class="flex-1">
            <h3 class="mb-2 text-sm font-semibold text-gray-500">Profil dominant</h3>
            <div class="text-xl font-bold text-secondary">Stratège analytique digital</div>
          </div>
          <div class="flex-1">
            <h3 class="mb-2 text-sm font-semibold text-gray-500">Potentiel inexploité</h3>
            <div class="text-xl font-bold text-green-600">Élevé</div>
          </div>
          <div class="flex-1">
            <h3 class="mb-2 text-sm font-semibold text-gray-500">Risque d’invisibilité</h3>
            <div class="text-xl font-bold text-yellow-600">Modéré</div>
          </div>
        </div>
        
        <div class="rounded-2xl bg-secondary p-5 text-white sm:p-8">
          <h3 class="text-primary font-bold mb-6 flex items-center text-lg">
            <span class="material-icons mr-2">trending_up</span>
            Trajectoires recommandées
          </h3>
          <ul class="space-y-4 font-light text-lg">
            <li class="flex items-center">
              <span class="w-1.5 h-1.5 bg-primary rounded-full mr-3"></span>
              Chargé d’études junior
            </li>
            <li class="flex items-center">
              <span class="w-1.5 h-1.5 bg-primary rounded-full mr-3"></span>
              Consultant data ONG
            </li>
            <li class="flex items-center">
              <span class="w-1.5 h-1.5 bg-primary rounded-full mr-3"></span>
              Assistant transformation digitale
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Public Cible Section -->
<section id="public" class="scroll-mt-8 bg-white py-16 text-secondary md:py-24">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-16">
      <div class="lg:w-1/2">
        <h2 class="lp-section-title mb-4"><%= t('home.target.title') %></h2>

        <p class="lp-section-copy mb-8 text-xl">
          <%= t('home.target.subtitle') %>
        </p>

        <div class="grid sm:grid-cols-2 gap-8">
          <% [
            { icon: "school", title: "Étudiants", desc: "En fin de cycle universitaire" },
            { icon: "work_off", title: "Jeunes diplômés", desc: "Actuellement sans emploi" },
            { icon: "trending_up", title: "Professionnels", desc: "Souhaitant évoluer vers le digital" },
            { icon: "history_edu", title: "Profils SHS", desc: "Lettres, sciences humaines, droit" }
          ].each do |item| %>
            <div class="flex flex-col">
              <span class="material-icons text-primary !text-4xl mb-4"><%= item[:icon] %></span>
              <h4 class="font-bold text-xl mb-2"><%= item[:title] %></h4>
              <p class="text-gray-600"><%= item[:desc] %></p>
            </div>
          <% end %>
        </div>
      </div>
      <div class="rounded-2xl border border-gray-200 bg-gray-50 p-2 lg:w-1/2">
        <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?auto=format&fit=crop&w=800&q=80" alt="Jeunes professionnels échangeant autour d'une table" loading="lazy" class="rounded-xl">
      </div>
    </div>
  </div>
</section>

<!-- Tarification -->
<section id="pricing" class="relative scroll-mt-8 overflow-hidden bg-secondary py-16 md:py-24">
  <div class="container relative z-10 mx-auto px-4 sm:px-6">
    <div class="mb-10 text-center md:mb-16">
      <h2 class="mb-4 text-balance text-4xl font-bold leading-tight text-white"><%= t('home.pricing.title') %></h2>

      <p class="text-sm font-semibold text-primary"><%= t('home.pricing.subtitle') %></p>

    </div>
    
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Diagnostic Essentiel -->
      <div class="relative rounded-2xl border border-gray-200 bg-white p-6 sm:p-10">
        <h3 class="text-2xl font-bold text-secondary mb-2"><%= t('home.pricing.essential') %></h3>

        <div class="text-4xl font-black text-secondary mb-6 flex items-baseline">
          <%= Diagnostic.formatted_price.gsub(" F CFA", "") %> <span class="text-sm ml-1 font-bold text-gray-400">F CFA</span>
        </div>
        <div class="h-px bg-gray-100 mb-8 w-full"></div>
        <ul class="space-y-4 text-gray-600 mb-10">
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> Évaluation complète</li>

          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> Rapport de score immédiat</li>
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> Profil dominant identifié</li>
          <li class="flex items-center"><span class="material-icons text-green-500 mr-3 !text-lg">check_circle</span> 3 trajectoires conseillées</li>
        </ul>
        <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-secondary min-h-12 w-full" do %>
          <span><%= t('home.pricing.order') %></span>
          <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        <% end %>
      </div>

      <!-- Roadmap Premium -->
      <div class="relative rounded-2xl border border-white/25 bg-white/5 p-6 text-white sm:p-10">
        <h3 class="text-2xl font-bold text-primary mb-2"><%= t('home.pricing.premium') %></h3>

        <div class="text-4xl font-black mb-6 flex items-baseline">
          Contactez-nous
        </div>
        <div class="h-px bg-white/10 mb-8 w-full"></div>
        <ul class="space-y-4 text-gray-300 mb-10">
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Tout du Diagnostic Essentiel</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Plan détaillé 6-12 mois</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Compétences à développer</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Outils digitaux à maîtriser</li>
          <li class="flex items-center"><span class="material-icons text-primary mr-3 !text-lg">auto_awesome</span> Étapes concrètes de mise en œuvre</li>
        </ul>
        <a href="mailto:contact@languesmetiers.com" class="lp-action-primary min-h-12 w-full">
          <span>Prendre RDV</span>
          <svg class="h-4 w-4 text-secondary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA Section -->
<section class="relative bg-white py-16 md:py-24">
  <div class="container mx-auto px-4 text-center sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="lp-section-title mb-4">
        Une trajectoire professionnelle se structure. <br/>Elle ne s'improvise pas.
      </h2>
      <p class="lp-section-copy mx-auto mb-8 max-w-2xl text-xl"><%= t('home.final.subtitle') %></p>

      
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
        <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-primary min-h-12 w-full px-6 py-4 text-base sm:w-auto sm:px-10 sm:text-lg" do %>
          <span><%= t('home.final.cta') %></span>

        <% end %>
      </div>
      
    </div>
  </div>
</section>
