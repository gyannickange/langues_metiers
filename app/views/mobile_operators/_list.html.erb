<%# app/views/mobile_operators/_list.html.erb %>
<% operators.each do |op| %>
  <label class="diagnostic-choice group relative flex items-center gap-4 min-h-11 p-4 border border-secondary-300 rounded-xl cursor-pointer hover:bg-white/10 transition-colors">
    <div class="relative flex items-center justify-center">
      <input type="radio" name="operator_code" value="<%= op.code %>" required class="peer appearance-none w-5 h-5 border-2 border-secondary-200 rounded-full checked:border-primary checked:bg-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary transition-colors cursor-pointer">
    </div>
    <span class="text-sm font-bold text-secondary-100 group-hover:text-white transition-colors"><%= op.name %></span>
  </label>
<% end %>
