<% content_for :title, "Insertrix - Métiers" %>

<% content_for :header do %>
  <section class="relative overflow-hidden bg-[#fbfbfb] font-sans text-secondary">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -left-16 top-32 h-32 w-32 rounded-full bg-primary opacity-25"></div>
    </div>

    <div class="relative z-10">
      <%= render "shared/lp_navigation" %>

      <div class="container mx-auto px-4 pb-12 sm:px-6 md:pb-16 lg:pb-20">
        <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-16">
          <div data-home-motion-target="hero" class="max-w-2xl py-8 lg:py-16">
            <h1 class="mb-6 text-balance text-4xl font-extrabold leading-[1.1] tracking-tight text-secondary sm:text-5xl lg:text-[3.25rem]">
              Explorez les métiers qui
              <span class="relative mt-2 inline-block px-2 py-1 sm:px-4 sm:py-2">
                <span class="absolute inset-0 rounded-lg bg-primary/20"></span>
                <span class="relative z-10">valorisent votre profil</span>
              </span>
            </h1>

            <p class="mb-8 max-w-xl text-pretty text-lg leading-relaxed text-gray-600 lg:text-xl">
              Découvrez 20 métiers d'avenir dans les secteurs stratégiques, conçus pour valoriser les compétences des sciences humaines, lettres et langues.
            </p>

            <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-primary min-h-12 w-full text-base sm:w-auto sm:px-8 sm:text-lg" do %>
              Faire mon diagnostic
            <% end %>
          </div>

          <div data-home-motion-target="hero" class="relative h-[320px] overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 sm:h-[420px] lg:h-[520px]">
            <%= image_tag "cinematic_career_hero.png", alt: "Professionnels explorant leurs perspectives de carrière", fetchpriority: "high", class: "h-full w-full object-cover object-center" %>
          </div>
        </div>
      </div>
    </div>
  </section>
<% end %>

<section id="careers" class="relative overflow-hidden bg-gray-50 py-16 md:py-24">
  <div class="container relative z-10 mx-auto px-4 sm:px-6">
    <div class="mb-10 text-center md:mb-16">
      <h2 class="lp-section-title mb-4">Des trajectoires adaptées à vos forces</h2>
      <p class="lp-section-copy mx-auto max-w-2xl text-lg">
        Explorez les secteurs où vos compétences peuvent devenir un avantage concret.
      </p>
    </div>

    <div data-home-motion-target="group" class="is-visible grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-8 lg:grid-cols-3 lg:gap-10">
      <% @careers.each_with_index do |career, index| %>
        <%= render "shared/career_card", career: career, index: index, heading_tag: :h2 %>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-white py-16 md:py-24">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="rounded-3xl bg-secondary p-6 text-white sm:p-12 lg:p-20">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-balance text-3xl font-bold leading-tight md:text-5xl">
          Prêt à découvrir votre voie stratégique ?
        </h2>
        <p class="mx-auto mb-10 max-w-2xl text-pretty text-lg leading-relaxed text-white/75 md:text-xl">
          Passez notre diagnostic pour croiser vos intérêts, vos compétences et les réalités du marché de l'emploi.
        </p>

        <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-primary min-h-12 w-full px-6 py-4 text-base sm:w-auto sm:px-10 sm:text-lg" do %>
          Démarrer mon diagnostic
        <% end %>
      </div>
    </div>
  </div>
</section>
