<%#
  Usage: 
  render "shared/stat_card",
         title: "Users",
         count: User.count,
         description: "Manage platform users",
         icon: :users,
         url: admin_users_path,
         color_scheme: "primary",
         percentage: 75,
         animation_delay: "0.1s"
%>
<%
  color_scheme ||= "primary"
  animation_delay ||= "0s"
  url ||= nil
  percentage ||= nil
  
  color_vars = {
    primary: "text-[var(--color-primary)] bg-[var(--color-primary)]/10",
    secondary: "text-[var(--color-secondary)] bg-[var(--color-secondary)]/10",
    accent: "text-[var(--color-accent)] bg-[var(--color-accent)]/10"
  }
  
  active_color = color_vars[color_scheme.to_sym] || color_vars[:primary]
%>

<% card_classes = "group glass-card rounded-2xl p-6 transition-all duration-300 hover:translate-y-[-4px] animate-premium-in" %>
<% card_style = "animation-delay: #{animation_delay};" %>

<% content = capture do %>
  <div class="flex items-start justify-between mb-4">
    <% if percentage %>
      <div class="w-16 h-16 chart-circle">
        <svg viewBox="0 0 36 36" class="text-[var(--color-primary)] transition-all duration-1000">
           <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                 fill="none" stroke="currentColor" stroke-opacity="0.1" stroke-width="2" />
           <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                 fill="none" stroke="currentColor" stroke-width="2.5" 
                 stroke-dasharray="<%= percentage %>, 100" stroke-linecap="round" />
        </svg>
        <div class="chart-percentage text-lg"><%= percentage %>%</div>
      </div>
    <% else %>
      <div class="w-12 h-12 rounded-xl flex items-center justify-center <%= active_color %> group-hover:scale-110 transition-transform duration-300">
        <%= lucide_icon icon.to_s.gsub('_', '-'), class: "w-6 h-6" %>
      </div>
    <% end %>
    <div class="text-right">
      <div class="text-3xl font-bold tracking-tight"><%= count %></div>
      <div class="text-[10px] text-muted-foreground font-black uppercase tracking-wider"><%= t("admin.dashboard.total") %></div>
    </div>
  </div>
  <h3 class="text-lg font-bold mb-1 font-display"><%= title %></h3>
  <p class="text-xs text-muted-foreground leading-relaxed"><%= description %></p>
  
  <% if url %>
    <div class="mt-6 flex items-center text-primary font-bold text-[10px] uppercase tracking-widest group-hover:translate-x-1 transition-transform duration-300">
      <%= t("admin.dashboard.view_all") %>
      <%= lucide_icon "chevron-right", class: "w-3 h-4 ml-1" %>
    </div>
  <% end %>
<% end %>

<% if url %>
  <%= link_to url, class: card_classes, style: card_style do %>
    <%= content %>
  <% end %>
<% else %>
  <div class="<%= card_classes %>" style="<%= card_style %>">
    <%= content %>
  </div>
<% end %>

