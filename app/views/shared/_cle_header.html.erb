<section class="primary-cle secondary-cle relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-primary-50 via-white to-secondary-50 pt-20 lg:pt-0">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-60 h-60 sm:w-80 sm:h-80 bg-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-64 h-64 sm:w-96 sm:h-96 bg-secondary/10 rounded-full blur-3xl"></div>
    <div class="absolute top-20 left-10 sm:left-20 w-16 h-16 sm:w-20 sm:h-20 bg-primary/20 rounded-full animate-pulse"></div>
    <div class="absolute bottom-40 right-10 sm:right-20 w-12 h-12 sm:w-16 sm:h-16 bg-secondary/20 rounded-full animate-bounce"></div>
  </div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-12 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Contenu gauche -->
      <div class="space-y-8 lg:space-y-10 order-2 lg:order-1 mt-8 lg:mt-0">
        <div class="space-y-6">
            <div class="flex items-center">
              <%= image_tag "cle-logo.png",
                            alt: "Citoyens Libres et Épanouis",
                            class: "hidden sm:block w-[7rem] lg:w-[10rem] h-auto",
                            loading: "eager",
                            decoding: "async" %>
            </div>
          <div class="inline-flex items-center bg-gradient-to-r from-primary/20 to-secondary/20 text-secondary text-xs sm:text-sm font-semibold px-4 sm:px-6 py-2 sm:py-3 rounded-full backdrop-blur-sm border border-primary/30">
            <span class="w-2 h-2 bg-primary rounded-full mr-2 sm:mr-3 animate-pulse"></span>
            PROGRAMME CLE 2025
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-secondary leading-tight">
            Citoyens 
            <span class="relative inline-block">
              Libres
              <div class="absolute -bottom-1 sm:-bottom-2 left-0 w-full h-2 sm:h-4 bg-primary/30 -skew-x-12 transform"></div>
            </span>
            et 
            <span class="bg-gradient-to-r from-primary-600 to-primary-500 bg-clip-text text-transparent block sm:inline">
              Épanouis
            </span>
          </h1>
          <p class="text-base sm:text-xl lg:text-2xl text-gray-600 leading-relaxed font-light">
            Transforme ta vision entrepreneuriale en réalité concrète. 
            Rejoins une communauté de <span class="font-semibold text-secondary block sm:inline">30 entrepreneures ambitieuses</span> pour 3 mois d'accompagnement intensif.
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
          <button class="group relative bg-gradient-to-r from-primary to-primary-600 text-primary-foreground px-6 sm:px-10 py-4 sm:py-5 rounded-2xl font-semibold text-base sm:text-lg transition-all duration-500 transform hover:scale-105 shadow-xl hover:shadow-2xl overflow-hidden w-full sm:w-auto">
            <span class="relative z-10 text-white">Rejoindre le programme</span>
            <div class="absolute inset-0 bg-gradient-to-r from-primary-600 to-primary-700 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </button>
          <button class="group relative border-2 border-secondary text-secondary hover:text-white px-6 sm:px-10 py-4 sm:py-5 rounded-2xl font-semibold text-base sm:text-lg transition-all duration-500 overflow-hidden w-full sm:w-auto">
            <span class="relative z-10">En savoir plus</span>
            <div class="absolute inset-0 bg-secondary transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </button>
        </div>
      </div>
      
      <!-- Image droite améliorée -->
      <div class="relative order-1 lg:order-2 px-2 sm:px-0">
        <div class="relative z-20">
          <div class="relative overflow-hidden rounded-3xl shadow-2xl transform lg:rotate-2 hover:rotate-0 transition-transform duration-700">
            <!-- Image Mobile (portrait) -->
            <img src="https://images.unsplash.com/photo-1531123414780-45a91130dd93?auto=format&fit=crop&w=600&q=80" 
                 alt="Entrepreneure CLE Mobile" 
                 class="w-full h-[350px] object-cover sm:hidden transform hover:scale-105 transition-transform duration-700">
            <!-- Image Desktop/Tablet (paysage) -->
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=800&q=80" 
                 alt="Entrepreneures CLE" 
                 class="hidden sm:block w-full sm:h-auto object-cover transform hover:scale-105 transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-secondary/40 lg:from-secondary/20 to-transparent"></div>
          </div>
        </div>
        
        <!-- Éléments décoratifs améliorés -->
        <div class="hidden sm:block absolute -top-8 -right-8 w-32 h-32 bg-gradient-to-br from-primary/30 to-primary/10 rounded-full blur-xl animate-pulse"></div>
        <div class="hidden sm:block absolute -bottom-8 -left-8 w-40 h-40 bg-gradient-to-br from-secondary/30 to-secondary/10 rounded-full blur-xl animate-pulse" style="animation-delay: 1s;"></div>
      </div>
    </div>
  </div>
</section>