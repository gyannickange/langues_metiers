<section class="relative min-h-screen overflow-hidden bg-[#fbfbfb] text-secondary font-sans">
  
  <!-- Formes géométriques décoratives (basées sur l'image) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Demi-cercle bleu à gauche -->
    <div class="absolute -left-16 top-32 w-32 h-32 bg-primary rounded-full opacity-90"></div>
    <!-- Cercle jaune en haut à gauche -->
    <div class="absolute left-1/4 -top-8 w-16 h-16 bg-primary-300 rounded-full opacity-60"></div>
    <!-- Cercle vert en bas  -->
    <div class="absolute left-1/3 -bottom-10 w-24 h-24 bg-primary-400 rounded-full opacity-40"></div>
    <!-- Cercle mauve clair au milieu/bas -->
    <div class="absolute left-1/2 bottom-20 w-12 h-12 bg-secondary-300 rounded-full opacity-20"></div>
  </div>
  
  <div class="relative z-10" data-controller="mobile-menu">
    <header class="container mx-auto px-6 py-8">
      <div class="flex items-center justify-between">
        
        <!-- Logo -->
        <div class="flex items-center group">
          <span class="text-3xl font-extrabold text-secondary tracking-tight">
            Insertrice<span class="text-primary">.</span>
          </span>
        </div>
        
        <!-- Navigation -->
        <nav class="hidden lg:flex items-center space-x-8 font-medium text-gray-600">
          <a class="hover:text-primary transition-colors duration-300" href="#"><%= t('home.navigation.home') %></a>
          <%= link_to "Les Métiers", careers_path, class: "hover:text-primary transition-colors duration-300" %>
          <%= link_to "Nouveau Diagnostic", (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "hover:text-primary transition-colors duration-300" %>
          <%= link_to "CLE", cle_path, class: "hover:text-primary transition-colors duration-300" %>
          <a class="hover:text-primary transition-colors duration-300" href="#"><%= t('home.navigation.about') %></a>
          <a class="hover:text-primary transition-colors duration-300" href="#"><%= t('home.navigation.contact') %></a>
        </nav>
        
        <!-- Action / Profile (Desktop) -->
        <div class="hidden lg:flex items-center space-x-6">
          <% if user_signed_in? %>
            <%= link_to t('home.navigation.dashboard'), admin_root_path, class: "btn-premium-primary py-2.5 px-6" %>

            <div class="relative group">
              <!-- Avatar -->
              <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center cursor-pointer overflow-hidden border-2 border-white shadow-sm hover:border-primary transition-all">
                <%# If User has an avatar attached %>
                <% if current_user.respond_to?(:avatar) && current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "w-full h-full object-cover" %>
                <% else %>
                  <span class="text-primary font-bold text-sm"><%= current_user.email[0..1].upcase %></span>
                <% end %>
              </div>
              
              <!-- Dropdown (Hover) -->
              <div class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
                <%= link_to profile_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                  <span class="material-icons text-lg mr-3 text-gray-400">person_outline</span>
                  <span><%= t('home.navigation.profile') %></span>
                <% end %>
                <div class="h-px bg-gray-100 my-1 mx-2"></div>
                <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors" do %>
                  <span class="material-icons text-lg mr-3 text-red-400">logout</span>
                  <span><%= t('home.navigation.logout') %></span>
                <% end %>

              </div>
            </div>
          <% else %>
            <%= link_to t('home.navigation.login'), new_user_session_path, class: "btn-premium-secondary py-2.5 px-6" %>
          <% end %>
          
          <!-- Language Switcher -->
          <div class="flex items-center space-x-2 border-l border-gray-200 pl-6 ml-2">
            <% if I18n.locale == :fr %>
              <%= link_to "EN", root_path(locale: :en), class: "text-sm font-bold text-gray-400 hover:text-primary transition-colors" %>
              <span class="text-secondary font-bold text-sm">FR</span>
            <% else %>
              <span class="text-secondary font-bold text-sm">EN</span>
              <%= link_to "FR", root_path(locale: :fr), class: "text-sm font-bold text-gray-400 hover:text-primary transition-colors" %>
            <% end %>
          </div>
        </div>


        <!-- Mobile menu button -->
        <div class="lg:hidden flex items-center">
          <button data-action="click->mobile-menu#toggle" type="button" class="text-gray-600 hover:text-primary focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary rounded-md p-2">
            <span class="sr-only">Open main menu</span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu (Hidden by default) -->
      <div data-mobile-menu-target="menu" class="hidden lg:hidden mt-4 pb-4 bg-white/95 backdrop-blur-md rounded-2xl shadow-xl absolute left-4 right-4 z-50 px-4 border border-gray-100">
        <nav class="flex flex-col space-y-4 pt-6">
          <a class="text-gray-700 hover:text-primary font-medium transition-colors" href="#" data-action="click->mobile-menu#close"><%= t('home.navigation.home') %></a>
          <%= link_to "Les Métiers", careers_path, class: "text-gray-700 hover:text-primary font-medium transition-colors", data: { action: "click->mobile-menu#close" } %>
          <%= link_to "CLE", cle_path, class: "text-gray-700 hover:text-primary font-medium transition-colors", data: { action: "click->mobile-menu#close" } %>
          <%= link_to "Nouveau Diagnostic", (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "text-gray-700 hover:text-primary font-medium transition-colors", data: { action: "click->mobile-menu#close" } %>
          <a class="text-gray-700 hover:text-primary font-medium transition-colors" href="#" data-action="click->mobile-menu#close"><%= t('home.navigation.about') %></a>
          <a class="text-gray-700 hover:text-primary font-medium transition-colors" href="#" data-action="click->mobile-menu#close"><%= t('home.navigation.contact') %></a>
          
          <div class="h-px bg-gray-100 w-full my-4"></div>
          
          <% if user_signed_in? %>
            <%= link_to admin_root_path, class: "flex items-center space-x-3 text-gray-700 hover:text-primary font-medium transition-colors" do %>
              <span class="material-icons">dashboard</span>
              <span><%= t('home.navigation.dashboard') %></span>
            <% end %>
            <%= link_to profile_path, class: "flex items-center space-x-3 text-gray-700 hover:text-primary font-medium transition-colors" do %>
              <span class="material-icons">person_outline</span>
              <span><%= t('home.navigation.profile') %></span>
            <% end %>
            <div class="h-px bg-gray-100 w-full my-4"></div>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center justify-center space-x-2 bg-red-600 text-white font-semibold py-3 rounded-full hover:bg-opacity-90 shadow-lg shadow-red-600/20 transition-colors mt-4" do %>
              <span class="material-icons">logout</span>
              <span><%= t('home.navigation.logout') %></span>
            <% end %>

          <% else %>
            <%= link_to form_authenticity_token == 'test' ? '#' : new_user_session_path, class: "btn-premium-secondary w-full justify-center py-3 mt-4" do %>
              <span><%= t('home.navigation.login') %></span>
            <% end %>
          <% end %>

          <div class="flex items-center justify-center space-x-4 pt-6">
            <%= link_to "Français", root_path(locale: :fr), class: "text-sm #{I18n.locale == :fr ? 'font-bold text-secondary' : 'text-gray-500'}" %>
            <span class="text-gray-200">|</span>
            <%= link_to "English", root_path(locale: :en), class: "text-sm #{I18n.locale == :en ? 'font-bold text-secondary' : 'text-gray-500'}" %>
          </div>
        </nav>
      </div>

    </header>
    
    <main class="container mx-auto px-6 pb-12 lg:pb-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        <!-- Contenu Gauche -->
        <div class="max-w-2xl xl:pr-12 mt-12 lg:mt-0 animate-fade-in-up">
          <h1 class="text-5xl lg:text-[3.6rem] font-extrabold text-secondary leading-[1.1] mb-8 tracking-tight">
            <%= t('home.hero.title_part1') %>
            <span class="relative inline-block px-4 py-2 mt-2">
              <span class="absolute inset-0 bg-primary/20 text-secondary rounded-xl transform -rotate-1"></span>
              <span class="relative z-10 text-secondary"><%= t('home.hero.title_part2') %></span>
              
              <!-- Sparkles effect based on screenshot -->
              <div class="absolute -top-10 -right-8 w-16 h-16 text-primary opacity-80 animate-pulse pointer-events-none">
                <svg viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <!-- Large sparkle -->
                  <path d="M50 0 L56 38 L94 44 L56 50 L50 88 L44 50 L6 44 L44 38 Z" />
                  <!-- Smaller top right sparkle -->
                  <path d="M85 10 L88 22 L100 25 L88 28 L85 40 L82 28 L70 25 L82 22 Z" />
                  <!-- Smaller left sparkle -->
                  <path d="M20 20 L22 28 L30 30 L22 32 L20 40 L18 32 L10 30 L18 28 Z" />
                </svg>
              </div>
            </span> 
            <br/><%= t('home.hero.title_part3') %>
          </h1>

          <p class="text-lg lg:text-xl text-gray-600 mb-10 max-w-xl font-light leading-relaxed">
            <%= t('home.hero.description') %>
          </p>

          <!-- CTA Bas -->
          <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "btn-premium-primary text-[1.2rem] py-3 px-8" do %>
            <%= t('home.hero.cta') %>
          <% end %>

        </div>

        <!-- Contenu Droite (Image hero-sideimg.png) -->
        <div class="relative w-full h-[600px] lg:h-[868px] flex justify-center lg:justify-end mt-12 lg:mt-0 xl:-mr-20">
          <%= image_tag "hero-sideimg.png", class: "lg:w-full h-full object-contain lg:object-cover object-left lg:object-center relative z-10 animate-fade-in-up" %>
        </div>
      </div>
    </main>
  </div>
</section>
