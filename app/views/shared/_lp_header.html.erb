<section class="relative min-h-[100svh] overflow-hidden bg-[#fbfbfb] font-sans text-secondary">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -left-16 top-32 h-32 w-32 rounded-full bg-primary opacity-25"></div>
  </div>

  <div class="relative z-10">
    <%= render "shared/lp_navigation", home_anchors: true %>

    <main class="container mx-auto px-4 pb-10 sm:px-6 sm:pb-12 lg:pb-0">
      <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-12">
        <div data-home-motion-target="hero" class="mt-8 max-w-3xl sm:mt-12 lg:mt-0 xl:pr-12">
          <h1 class="mb-6 max-w-2xl text-balance text-4xl font-extrabold leading-[1.1] tracking-tight text-secondary sm:text-5xl lg:mb-8 lg:text-[2.7rem]">
            <%= t("home.hero.title_part1") %>
            <span class="relative mt-2 inline-block px-2 py-1 sm:px-4 sm:py-2">
              <span class="absolute inset-0 rounded-lg bg-primary/20 text-secondary"></span>
              <span class="relative z-10 text-secondary"><%= t("home.hero.title_part2") %></span>
            </span>
            <br><%= t("home.hero.title_part3") %>
          </h1>

          <p class="mb-8 max-w-xl text-pretty text-lg leading-relaxed text-gray-600 lg:mb-10 lg:text-xl">
            <%= t("home.hero.description") %>
          </p>

          <%= link_to (user_signed_in? ? new_diagnostic_path : new_user_session_path(redirect_to: new_diagnostic_path)), class: "lp-action-primary min-h-12 w-full text-base sm:w-auto sm:px-8 sm:text-lg" do %>
            <%= t("home.hero.cta") %>
          <% end %>
        </div>

        <div data-home-motion-target="hero" class="relative mt-6 flex h-[360px] w-full justify-center sm:mt-10 sm:h-[500px] lg:mt-0 lg:h-[868px] lg:justify-end xl:-mr-20">
          <%= image_tag "hero-sideimg.webp", alt: "Jeune diplômée construisant sa trajectoire professionnelle", fetchpriority: "high", class: "relative z-10 h-full object-contain object-left lg:w-full lg:object-cover lg:object-center" %>
        </div>
      </div>
    </main>
  </div>
</section>
