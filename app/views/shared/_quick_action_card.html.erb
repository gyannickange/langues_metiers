<%#
  Usage:
  render "shared/quick_action_card",
         title: "Manage users",
         count: User.count,
         icon: :users,
         url: admin_users_path,
         color_scheme: "primary"
%>
<%
  color_scheme ||= "primary"
  
  color_vars = {
    primary: "text-[var(--color-primary)] bg-[var(--color-primary)]/10",
    secondary: "text-[var(--color-secondary)] bg-[var(--color-secondary)]/10",
    accent: "text-[var(--color-accent)] bg-[var(--color-accent)]/10"
  }
  
  active_color = color_vars[color_scheme.to_sym] || color_vars[:primary]
%>

<%= link_to url, class: "glass-card rounded-xl p-5 hover:translate-y-[-2px] transition-all duration-300 group" do %>
  <div class="flex items-center space-x-4">
    <div class="w-10 h-10 rounded-lg flex items-center justify-center <%= active_color %> group-hover:scale-110 transition-transform duration-300">
      <%= lucide_icon icon, class: "w-5 h-5" %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="font-bold text-slate-800 truncate font-display uppercase tracking-wider text-sm"><%= title %></div>
      <% if defined?(count) && count.present? %>
        <div class="text-[10px] text-slate-500 font-black uppercase tracking-widest mt-0.5">
          <%= count %> <%= (defined?(count_label) ? count_label : "items").downcase %>
        </div>
      <% end %>
    </div>
    <%= lucide_icon :chevron_right, class: "w-4 h-4 text-slate-300 group-hover:text-[var(--color-secondary)] group-hover:translate-x-1 transition-all" %>
  </div>
<% end %>

