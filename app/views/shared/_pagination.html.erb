<%# 
  Usage: render partial: "shared/pagination", locals: { pagy: @pagy }
%>
<% if pagy.pages > 1 %>
  <div class="flex items-center justify-between bg-white/50 backdrop-blur-sm px-6 py-4">
    <div class="flex flex-1 justify-between sm:hidden">
      <% if pagy.prev %>
        <% query_params = request.query_parameters.merge(page: pagy.prev) %>
        <%= link_to t("actions.previous"), "#{request.path}?#{query_params.to_query}", class: "relative inline-flex items-center rounded-xl bg-white px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-700 shadow-sm transition-all hover:bg-slate-50" %>
      <% else %>
        <span class="relative inline-flex items-center rounded-xl bg-slate-50 px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-400 cursor-not-allowed"><%= t("actions.previous") %></span>
      <% end %>
      <% if pagy.next %>
        <% query_params = request.query_parameters.merge(page: pagy.next) %>
        <%= link_to t("actions.next"), "#{request.path}?#{query_params.to_query}", class: "relative ml-3 inline-flex items-center rounded-xl bg-white px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-700 shadow-sm transition-all hover:bg-slate-50" %>
      <% else %>
        <span class="relative ml-3 inline-flex items-center rounded-xl bg-slate-50 px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-400 cursor-not-allowed"><%= t("actions.next") %></span>
      <% end %>
    </div>
    <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
      <div>
        <p class="text-[10px] text-slate-500 font-black uppercase tracking-widest">
          <%= t("pagination.showing", from: pagy.from, to: pagy.to, total: pagy.count) %>
        </p>
      </div>
      <div>
        <nav class="isolate inline-flex -space-x-px" aria-label="Pagination">
          <% pagy.series.each do |item| %>
            <% if item.is_a?(Integer) %>
              <% query_params = request.query_parameters.merge(page: item) %>
              <%= link_to item, "#{request.path}?#{query_params.to_query}", 
                  class: "relative inline-flex items-center px-4 py-2 text-xs font-bold transition-all first:rounded-l-xl last:rounded-r-xl #{item == pagy.page ? 'z-10 bg-[var(--color-primary)] text-white' : 'text-slate-600 bg-white hover:bg-slate-50 text-slate-900 shadow-sm'}" %>
            <% elsif item == :gap %>
              <span class="relative inline-flex items-center px-4 py-2 text-xs font-bold text-slate-400 bg-white shadow-sm">...</span>
            <% elsif item == :prev_page %>
              <% if pagy.prev %>
                <% query_params = request.query_parameters.merge(page: pagy.prev) %>
                <%= link_to "#{request.path}?#{query_params.to_query}", class: "relative inline-flex items-center rounded-l-xl px-2 py-2 text-slate-400 bg-white hover:bg-slate-50 shadow-sm transition-all" do %>
                  <span class="sr-only"><%= t("actions.previous") %></span>
                  <%= lucide_icon "chevron-left", class: "h-4 w-4" %>
                <% end %>
              <% end %>
            <% elsif item == :next_page %>
              <% if pagy.next %>
                <% query_params = request.query_parameters.merge(page: pagy.next) %>
                <%= link_to "#{request.path}?#{query_params.to_query}", class: "relative inline-flex items-center rounded-r-xl px-2 py-2 text-slate-400 bg-white hover:bg-slate-50 shadow-sm transition-all" do %>
                  <span class="sr-only"><%= t("actions.next") %></span>
                  <%= lucide_icon "chevron-right", class: "h-4 w-4" %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        </nav>
      </div>
    </div>
  </div>
<% end %>

