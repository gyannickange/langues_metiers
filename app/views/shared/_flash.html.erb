<div class="fixed top-6 right-6 z-[100] flex flex-col items-end space-y-4 px-4 w-full max-w-sm pointer-events-none" data-controller="flash">
  <% flash.each do |type, message| %>
    <% next if message.blank? %>
    <% 
      glass_css = case type.to_s
        when "notice" then "bg-emerald-500/10 border-emerald-500/20 text-emerald-900"
        when "alert" then "bg-rose-500/10 border-rose-500/20 text-rose-900"
        else "bg-amber-500/10 border-amber-500/20 text-amber-900"
      end
      
      icon = case type.to_s
        when "notice" then "check_circle"
        when "alert" then "error"
        else "info"
      end
    %>
    <div class="pointer-events-auto group w-full backdrop-blur-md border rounded-2xl shadow-xl p-4 flex items-center gap-4 animate-fade-in-up transition-all duration-500 hover:scale-[1.02] <%= glass_css %>" 
         data-flash-target="item"
         role="alert">
      
      <div class="flex-shrink-0">
        <span class="material-icons opacity-80"><%= icon %></span>
      </div>

      <div class="flex-1">
        <p class="text-sm font-medium leading-tight"><%= message %></p>
      </div>

      <button type="button" 
              class="flex-shrink-0 p-1 rounded-full hover:bg-black/5 transition-colors opacity-40 hover:opacity-100" 
              data-action="flash#dismiss"
              aria-label="Dismiss">
        <span class="material-icons text-lg">close</span>
      </button>
    </div>
  <% end %>
</div>


