<%#
  Usage:
  render "shared/table",
         columns: [
           { header: "Email",  cell: ->(r){ r.email } },
           { header: "Role",   cell: ->(r){ r.role } },
           { header: "Joined", cell: ->(r){ l(r.created_at, format: :short) } }
         ],
         rows: @users,
         pagy: local_assigns[:pagy]
%>

<% 
  # Dynamic grid columns fix for Tailwind JIT:
  has_actions = local_assigns[:actions].present?
  col_count = columns.size + (has_actions ? 1 : 0)

  col_widths = columns.map { |c| c[:width] || "minmax(0, 1fr)" }
  col_widths << (local_assigns[:actions_width] || "minmax(0, 1fr)") if has_actions
  
  grid_style = local_assigns[:grid_style] || "grid-template-columns: #{col_widths.join(' ')};"
%>

<div class="space-y-4 animate-premium-in">
  <!-- Table Header (Desktop only) -->
  <div class="hidden md:grid gap-4 px-8 py-4 bg-slate-50/50 rounded-2xl border border-slate-100/50" style="<%= grid_style %>">
    <% columns.each_with_index do |col, col_index| %>
      <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] <%= "md:pl-2" if col_index == 0 %>">
        <%= col[:header] %>
      </div>
    <% end %>
    <% if has_actions %>
      <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right md:pr-2">
        <%= t("Actions") %>
      </div>
    <% end %>
  </div>

  <!-- Rows / Cards -->
  <div class="space-y-3" <%= tag.attributes(local_assigns[:data] || {}) %>>
    <% rows.each do |row| %>
      <div class="group bg-white rounded-[2rem] p-6 md:px-8 md:py-5 border border-slate-100/80 shadow-sm hover:shadow-premium-lg hover:border-[var(--color-primary)]/30 transition-all duration-300 transform hover:-translate-y-1" data-id="<%= row.id %>">
        <div class="flex flex-col md:grid gap-4 items-start md:items-center" style="<%= grid_style %>">
          <% columns.each_with_index do |col, col_index| %>
            <div class="<%= col_index == 0 ? "flex flex-col gap-1 md:pl-2" : "w-full md:w-auto" %>">
              <% if col_index > 0 %>
                <span class="md:hidden text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1"><%= col[:header] %></span>
              <% end %>
              <div class="text-slate-700 font-bold transition-colors group-hover:text-slate-900 truncate">
                <%= col[:cell].call(row) %>
              </div>
            </div>
          <% end %>

          <% if has_actions %>
            <div class="w-full md:w-auto mt-4 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-slate-50 flex items-center justify-end gap-2 md:pr-2">
              <%= actions.call(row) %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if local_assigns[:pagy].present? && pagy.pages > 1 %>
    <div class="mt-8">
      <%= render "shared/pagination", pagy: pagy %>
    </div>
  <% end %>
</div>


