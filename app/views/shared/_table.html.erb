<%#
  Usage:
  render "shared/table",
         columns: [
           { header: "Email",  cell: ->(r){ r.email } },
           { header: "Role",   cell: ->(r){ r.role } },
           { header: "Joined", cell: ->(r){ l(r.created_at, format: :short) } }
         ],
         rows: @users,
         pagy: @pagy
%>

<div class="space-y-4 animate-premium-in">
  <!-- Table Header (Desktop only) -->
  <div class="hidden md:grid grid-cols-<%= columns.size + (defined?(actions) && actions ? 1 : 0) %> gap-4 px-8 py-4 bg-slate-50/50 rounded-2xl border border-slate-100/50">
    <% columns.each do |col| %>
      <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
        <%= col[:header] %>
      </div>
    <% end %>
    <% if defined?(actions) && actions %>
      <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right">
        <%= t("Actions") %>
      </div>
    <% end %>
  </div>

  <!-- Rows / Cards -->
  <div class="space-y-3">
    <% rows.each_with_index do |row, index| %>
      <div class="group bg-white rounded-[2rem] p-6 md:px-8 md:py-5 border border-slate-100/80 shadow-sm hover:shadow-premium-lg hover:border-[var(--color-primary)]/30 transition-all duration-300 transform hover:-translate-y-1">
        <div class="flex flex-col md:grid md:grid-cols-<%= columns.size + (defined?(actions) && actions ? 1 : 0) %> gap-4 items-start md:items-center">
          <% columns.each_with_index do |col, col_index| %>
            <div class="<%= "flex flex-col gap-1" if col_index == 0 %>">
              <% if col_index > 0 %>
                <span class="md:hidden text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1"><%= col[:header] %></span>
              <% end %>
              <div class="text-slate-700 font-bold transition-colors group-hover:text-slate-900">
                <%= col[:cell].call(row) %>
              </div>
            </div>
          <% end %>

          <% if defined?(actions) && actions %>
            <div class="w-full md:w-auto mt-4 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-slate-50 flex items-center justify-end gap-2">
              <%= actions.call(row) %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if defined?(pagy) && pagy.present? && pagy.pages > 1 %>
    <div class="mt-8">
      <%= render "shared/pagination", pagy: pagy %>
    </div>
  <% end %>
</div>


