<div class="flex flex-col h-full">
  <nav class="flex-1 space-y-1 py-4">
    <%= link_to admin_root_path, class: nav_link_class(admin_root_path) do %>
      <%= lucide_icon "layout-dashboard", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Dashboard") %></span>
    <% end %>

    <div class="pt-4 pb-2 px-4">
      <span class="text-[10px] font-black uppercase tracking-widest text-slate-400"><%= t("Management") %></span>
    </div>

    <%= link_to admin_users_path, class: nav_link_class(admin_users_path) do %>
      <%= lucide_icon "users", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Users") %></span>
    <% end %>

    <%= link_to admin_skills_path, class: nav_link_class(admin_skills_path) do %>
      <%= lucide_icon "layers", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Skills") %></span>
    <% end %>

    <%= link_to admin_careers_path, class: nav_link_class(admin_careers_path) do %>
      <%= lucide_icon "briefcase", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Careers") %></span>
    <% end %>

    <div class="pt-4 pb-2 px-4">
      <span class="text-[10px] font-black uppercase tracking-widest text-slate-400"><%= t("Resources") %></span>
    </div>

    <%= link_to "#", class: nav_link_class("#") do %>
      <%= lucide_icon "graduation-cap", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Learning Modules") %></span>
    <% end %>

    <%= link_to "#", class: nav_link_class("#") do %>
      <%= lucide_icon "handshake", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Mentorship") %></span>
    <% end %>

    <%= link_to "#", class: nav_link_class("#") do %>
      <%= lucide_icon "settings-2", class: "w-5 h-5" %>
      <span class="ml-3"><%= t("Settings") %></span>
    <% end %>
  </nav>

  <div class="p-4 bg-slate-50/50 rounded-3xl mb-6 mx-2 border border-slate-100/50">
    <div class="flex items-center justify-between">
      <div class="flex flex-col">
        <span class="text-xs font-bold text-slate-700">Busy Mode</span>
        <span class="text-[10px] text-slate-400">Restreindre l'accès</span>
      </div>
      <label class="relative inline-flex items-center cursor-pointer">
        <input type="checkbox" value="" class="sr-only peer">
        <div class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[var(--color-primary)]"></div>
      </label>
    </div>
  </div>
</div>


