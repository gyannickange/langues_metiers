<article data-career-card data-motion-item style="--motion-index: <%= index %>" class="relative flex flex-col justify-between rounded-2xl border border-gray-200 bg-white p-5 sm:p-8">
  <div class="mb-8 flex-grow">
    <div class="mb-6 flex items-center space-x-4">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-secondary-50 text-secondary-800">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
      </div>
      <%= content_tag heading_tag, career.title, class: "text-lg font-semibold leading-tight text-secondary-900" %>
    </div>

    <p class="line-clamp-3 text-sm leading-relaxed text-gray-600"><%= career.description %></p>
  </div>

  <div class="mt-auto border-t border-gray-100 pt-6">
    <div class="mb-2 flex items-center space-x-2">
      <svg class="h-4 w-4 text-secondary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
      <p class="text-xs font-semibold text-gray-500">Compétences clés</p>
    </div>
    <p class="text-xs font-bold leading-snug text-secondary-800"><%= career.key_skills.first(3).join(", ") %></p>
  </div>
</article>
