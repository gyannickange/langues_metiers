<%#
  Usage:
  render "shared/version_history", versions: @career.versions.reverse_chronological
%>

<div class="glass-card rounded-2xl p-6 shadow-premium animate-premium-in">
  <div class="flex items-center gap-3 mb-6 border-b border-slate-100 pb-4">
    <div class="p-2 bg-[var(--color-primary)]/10 text-[var(--color-primary)] rounded-lg">
      <%= lucide_icon "history", class: "h-5 w-5" %>
    </div>
    <h3 class="text-lg font-display text-slate-800">Historique des modifications</h3>
  </div>

  <% if versions.none? %>
    <p class="text-sm text-slate-400">Aucune modification enregistrée.</p>
  <% else %>
    <ul class="space-y-4">
      <% event_labels = { "create" => "Création", "update" => "Modification", "destroy" => "Suppression" } %>
      <% versions.each do |version| %>
        <li class="text-sm border-b border-slate-50 pb-3 last:border-0 last:pb-0">
          <div class="flex items-center justify-between">
            <span class="font-bold text-slate-700"><%= event_labels[version.event] || version.event %></span>
            <span class="text-xs text-slate-400"><%= l(version.created_at, format: :short) %></span>
          </div>
          <p class="text-xs text-slate-500 mt-1">
            Par
            <% admin = User.find_by(id: version.whodunnit) %>
            <%= admin&.email || (version.whodunnit.present? ? "Utilisateur ##{version.whodunnit}" : "Système") %>
          </p>
          <% if version.event == "update" && version.changeset.present? %>
            <ul class="mt-2 text-xs text-slate-600 list-disc list-inside">
              <% version.changeset.except("updated_at").each do |attribute, change| %>
                <% before, after = change %>
                <li><%= attribute %> : <span class="text-slate-400"><%= before.inspect %></span> &rarr; <%= after.inspect %></li>
              <% end %>
            </ul>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
