<%# 
  Usage: render partial: "shared/badge", locals: { text: "Published", color: "green" }
  Colors: gold, green, blue, purple, orange, yellow, red, gray, slate
%>
<% badge_classes = {
  gold: "bg-[var(--color-primary)]/10 text-[var(--color-primary)] border-[var(--color-primary)]/20",
  green: "bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] border-[var(--color-secondary)]/20",
  blue: "bg-blue-50 text-blue-600 border-blue-100",
  purple: "bg-purple-50 text-purple-600 border-purple-100",
  orange: "bg-orange-50 text-orange-600 border-orange-100",
  yellow: "bg-yellow-50 text-yellow-600 border-yellow-100",
  red: "bg-red-50 text-red-600 border-red-100",
  gray: "bg-slate-50 text-slate-600 border-slate-100",
  slate: "bg-slate-50 text-slate-600 border-slate-100"
} %>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase tracking-widest border <%= badge_classes[color.to_sym] || badge_classes[:slate] %>">
  <%= text %>
</span>

