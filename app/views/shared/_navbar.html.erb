<nav class="bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-100 sticky top-0 z-50 transition-transform duration-300 translate-y-0" data-controller="mobile-menu navbar-scroll" data-action="scroll@window->navbar-scroll#handleScroll">
  <div class="container mx-auto px-6 py-3">
    <div class="flex items-center justify-between">
