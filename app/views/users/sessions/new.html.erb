<% content_for :title, t("auth.login_title") %>

<section class="min-h-dvh bg-[#f7f8f6] font-sans text-secondary">
  <div class="grid min-h-dvh lg:grid-cols-[minmax(0,0.9fr)_minmax(32rem,1.1fr)]">
    <aside class="relative hidden overflow-hidden bg-secondary p-12 text-white lg:flex lg:flex-col lg:justify-between xl:p-16" aria-label="<%= t("auth.panel_aria_label") %>">
      <div class="pointer-events-none absolute -bottom-48 -right-40 h-[30rem] w-[30rem] rounded-full border border-primary/15" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -bottom-32 -right-24 h-[22rem] w-[22rem] rounded-full border border-primary/10" aria-hidden="true"></div>

      <%= link_to root_path, class: "relative z-10 w-fit rounded-lg text-3xl font-extrabold tracking-tight text-white focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-4 focus:ring-offset-secondary", aria: { label: t("auth.back_home") } do %>
        Insertrix<span class="text-primary">.</span>
      <% end %>

      <div class="relative z-10 max-w-xl py-12">
        <p class="mb-5 w-fit rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-bold text-primary">
          <%= t("auth.passwordless_label") %>
        </p>
        <h2 class="max-w-lg text-balance text-4xl font-extrabold leading-tight tracking-tight xl:text-5xl">
          <%= t("auth.panel_title") %>
        </h2>
        <p class="mt-6 max-w-lg text-pretty text-lg leading-relaxed text-white/75">
          <%= t("auth.panel_description") %>
        </p>

        <ol class="mt-10 space-y-5" aria-label="<%= t("auth.steps_aria_label") %>">
          <% [
            [t("auth.steps.email_title"), t("auth.steps.email_description")],
            [t("auth.steps.code_title"), t("auth.steps.code_description")],
            [t("auth.steps.access_title"), t("auth.steps.access_description")]
          ].each_with_index do |(title, description), index| %>
            <li class="flex max-w-lg items-start gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-secondary-900"><%= index + 1 %></span>
              <span>
                <strong class="block font-bold text-white"><%= title %></strong>
                <span class="mt-1 block text-sm leading-relaxed text-white/65"><%= description %></span>
              </span>
            </li>
          <% end %>
        </ol>
      </div>

      <p class="relative z-10 max-w-md text-sm leading-relaxed text-white/60"><%= t("auth.panel_footer") %></p>
    </aside>

    <main class="flex min-h-dvh items-center justify-center px-5 py-10 sm:px-10 lg:px-14">
      <div class="w-full max-w-lg">
        <div class="mb-10 flex items-center justify-between lg:hidden">
          <%= link_to root_path, class: "rounded-lg text-2xl font-extrabold tracking-tight text-secondary focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-4", aria: { label: t("auth.back_home") } do %>
            Insertrix<span class="text-primary-700">.</span>
          <% end %>
          <span class="rounded-full bg-secondary-50 px-3 py-1.5 text-sm font-bold text-secondary-800"><%= t("auth.otp_only") %></span>
        </div>

        <header class="mb-8">
          <h1 class="text-balance text-3xl font-extrabold tracking-tight text-secondary sm:text-4xl"><%= t("auth.login_title") %></h1>
          <p class="mt-4 max-w-md text-pretty text-base leading-relaxed text-secondary-700"><%= t("auth.login_subtitle") %></p>
        </header>

        <div class="rounded-2xl border border-secondary-900/10 bg-white p-6 shadow-sm sm:p-8">
          <%= turbo_frame_tag "auth_flow" do %>
            <%= form_with url: send_otp_path, method: :post, data: { turbo: true }, class: "space-y-6", aria: { label: t("auth.email_form_label") } do |f| %>
              <%= f.hidden_field :redirect_to, value: params[:redirect_to] %>

              <div>
                <%= f.label :email, t("auth.email_label"), class: "block text-sm font-bold text-secondary" %>
                <p id="email-hint" class="mt-1.5 text-sm leading-relaxed text-secondary-700"><%= t("auth.email_hint") %></p>
                <%= f.email_field :email,
                    placeholder: t("auth.email_placeholder"),
                    required: true,
                    autocomplete: "email",
                    aria: { describedby: "email-hint" },
                    class: "mt-3 min-h-12 w-full rounded-xl border border-secondary-900/15 bg-[#fafafa] px-4 py-3.5 text-base text-secondary shadow-inner placeholder:text-secondary-700 focus:border-secondary focus:bg-white focus:outline-none focus:ring-2 focus:ring-secondary/25" %>
              </div>

              <%= f.submit t("auth.email_submit"),
                  data: { turbo_submits_with: t("auth.sending_code") },
                  class: "min-h-12 w-full cursor-pointer rounded-xl border border-primary-700/20 bg-primary px-5 py-3.5 text-base font-extrabold text-secondary-900 shadow-sm transition-colors duration-200 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 disabled:cursor-wait disabled:opacity-70" %>

              <div class="flex items-start gap-3 rounded-xl bg-secondary-50 p-4 text-sm leading-relaxed text-secondary-800">
                <%= lucide_icon "shield-check", class: "mt-0.5 h-5 w-5 shrink-0 text-secondary-700", aria: { hidden: true } %>
                <p><%= t("auth.security_note") %></p>
              </div>
            <% end %>
          <% end %>
        </div>

        <p class="mx-auto mt-6 max-w-md text-center text-sm leading-relaxed text-secondary-700">
          <%= t("auth.legal_text", terms: link_to(t("auth.terms"), terms_path, class: "font-bold text-secondary underline decoration-primary-700 underline-offset-4 hover:text-primary-800 focus:outline-none focus:ring-2 focus:ring-secondary", target: "_top"), privacy: link_to(t("auth.privacy"), privacy_path, class: "font-bold text-secondary underline decoration-primary-700 underline-offset-4 hover:text-primary-800 focus:outline-none focus:ring-2 focus:ring-secondary", target: "_top")).html_safe %>
        </p>
      </div>
    </main>
  </div>
</section>
