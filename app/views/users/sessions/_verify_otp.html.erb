<%= turbo_frame_tag "auth_flow" do %>
  <div>
    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-secondary" aria-hidden="true">
      <%= lucide_icon "mail-check", class: "h-6 w-6" %>
    </div>

    <h2 class="mt-6 text-2xl font-extrabold tracking-tight text-secondary"><%= t("auth.verify_title") %></h2>
    <p class="mt-3 text-base leading-relaxed text-secondary-700">
      <%= t("auth.verify_subtitle") %>
      <strong class="block break-all font-bold text-secondary"><%= email %></strong>
    </p>

    <div class="mt-5 rounded-xl border border-primary-700/20 bg-primary-50 p-4 text-sm leading-relaxed text-secondary-800" role="status" aria-live="polite">
      <strong class="font-bold text-secondary"><%= t("auth.code_sent") %></strong>
      <span><%= t("auth.code_validity") %></span>
    </div>

    <%= form_with url: verify_otp_path, method: :post, data: { turbo: true, turbo_frame: "_top" }, class: "mt-6 space-y-6", aria: { label: t("auth.otp_form_label") } do |f| %>
      <%= f.hidden_field :email, value: email %>
      <%= f.hidden_field :redirect_to, value: local_assigns[:redirect_to] %>

      <% if flash[:alert] %>
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-800" role="alert" aria-live="assertive">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div>
        <%= f.label :otp_code, t("auth.otp_label"), class: "block text-sm font-bold text-secondary" %>
        <p id="otp-hint" class="mt-1.5 text-sm leading-relaxed text-secondary-700"><%= t("auth.otp_hint") %></p>
        <%= f.text_field :otp_code,
            required: true,
            maxlength: 6,
            autofocus: true,
            inputmode: "numeric",
            pattern: "[0-9]{6}",
            autocomplete: "one-time-code",
            aria: { describedby: "otp-hint", invalid: flash[:alert].present? },
            class: "mt-3 min-h-14 w-full rounded-xl border border-secondary-900/15 bg-[#fafafa] px-4 py-3.5 text-center font-mono text-2xl font-bold tracking-[0.35em] text-secondary shadow-inner focus:border-secondary focus:bg-white focus:outline-none focus:ring-2 focus:ring-secondary/25" %>
      </div>

      <%= f.submit t("auth.otp_submit"),
          data: { turbo_submits_with: t("auth.verifying_code") },
          class: "min-h-12 w-full cursor-pointer rounded-xl border border-primary-700/20 bg-primary px-5 py-3.5 text-base font-extrabold text-secondary-900 shadow-sm transition-colors duration-200 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 disabled:cursor-wait disabled:opacity-70" %>
    <% end %>

    <div class="mt-6 border-t border-secondary-900/10 pt-6 text-sm" data-controller="otp-resend" data-otp-resend-seconds-value="30" data-otp-resend-waiting-label-value="<%= t("auth.resend_waiting") %>">
      <p class="text-secondary-700"><%= t("auth.did_not_receive") %></p>
      <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-3">
        <%= button_to send_otp_path,
            method: :post,
            params: { email: email, redirect_to: local_assigns[:redirect_to] },
            form: { class: "inline", data: { turbo: true } },
            class: "min-h-11 rounded-lg font-bold text-secondary underline decoration-primary-700 underline-offset-4 transition-colors hover:text-primary-800 focus:outline-none focus:ring-2 focus:ring-secondary disabled:cursor-not-allowed disabled:text-secondary-600 disabled:no-underline",
            data: { otp_resend_target: "button", turbo_submits_with: t("auth.resending_code") } do %>
          <span data-otp-resend-target="label"><%= t("auth.resend_code") %></span>
        <% end %>

        <%= link_to t("auth.change_email"), new_user_session_path(redirect_to: local_assigns[:redirect_to]), data: { turbo: false }, class: "inline-flex min-h-11 items-center rounded-lg font-bold text-secondary-700 transition-colors hover:text-secondary focus:outline-none focus:ring-2 focus:ring-secondary" %>
      </div>
    </div>
  </div>
<% end %>
