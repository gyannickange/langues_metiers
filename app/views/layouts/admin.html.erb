<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin" %> · Insertrice</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-slate-50/50 antialiased font-sans">
    <%= render "shared/flash" %>
    
    <div data-controller="menu" class="min-h-screen flex flex-col md:flex-row p-0 md:p-4 lg:p-6 gap-0 md:gap-4 lg:gap-6">
      <!-- Sidebar / Navigation -->
      <aside data-menu-target="sidebar" 
             class="w-80 bg-white/80 backdrop-blur-xl border border-slate-200/50 rounded-none md:rounded-[2.5rem] shadow-premium hidden md:flex flex-col fixed inset-y-0 left-0 md:relative z-40 transform -translate-x-full md:translate-x-0 transition-all duration-500 ease-in-out">
        
        <div class="p-8 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="group flex items-center justify-center space-x-2 text-secondary hover:text-primary transition-colors duration-300">
              <span class="text-3xl font-extrabold tracking-tight">
                Insertrice<span class="text-primary">.</span>
              </span>
            </div>
          </div>
          <button data-action="menu#toggle" class="p-2 md:hidden text-slate-400 hover:text-slate-600 transition-colors">
            <%= lucide_icon "x", class: "w-6 h-6" %>
          </button>
        </div>

        <div class="flex-1 px-4 overflow-y-auto custom-scrollbar">
          <%= render "shared/sidebar" %>
        </div>

        <div class="p-6 mt-auto">
          <div class="bg-slate-50 rounded-3xl p-4 flex items-center justify-between border border-slate-100/50">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center overflow-hidden">
                <%= lucide_icon "user", class: "w-4 h-4 text-slate-400" %>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Admin Mode</span>
                <span class="text-xs font-bold text-slate-700 truncate w-24"><%= current_user&.email&.split('@')&.first %></span>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col min-w-0 bg-white/90 backdrop-blur-sm rounded-none md:rounded-[3rem] border border-slate-200/30 shadow-premium-lg overflow-hidden relative">
        <header class="h-20 flex items-center justify-between px-8 border-b border-slate-100/50 sticky top-0 z-30 bg-white/40 backdrop-blur-md">
          <div class="flex items-center gap-6 flex-1">
            <button class="md:hidden p-3 text-slate-600 hover:bg-slate-100 rounded-2xl transition-all" data-action="menu#toggle" aria-label="Open menu">
              <%= lucide_icon "menu", class: "w-6 h-6" %>
            </button>
            <h1 class="text-2xl font-black text-slate-800 tracking-tight"><%= content_for(:page_title) || "Dashboard" %></h1>
          </div>

          <div class="flex items-center gap-4">
            <div class="hidden sm:flex items-center gap-2 bg-slate-50 border border-slate-100 rounded-2xl px-4 py-2">
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
              <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">System Online</span>
            </div>
            
            <button class="p-3 text-slate-400 hover:text-slate-600 hover:bg-slate-50 rounded-2xl transition-all relative">
              <%= lucide_icon "bell", class: "w-5 h-5" %>
              <span class="absolute top-3 right-3 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
            </button>
          </div>
        </header>

        <main class="flex-1 p-6 md:p-10 lg:p-12 overflow-y-auto custom-scrollbar">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
  </html>


