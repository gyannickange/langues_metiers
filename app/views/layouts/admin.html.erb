<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin" %> · Insertrice</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-[var(--color-surface-50)] antialiased">
    <%= render "shared/flash" %>
    <div data-controller="menu" class="min-h-screen flex">
      <aside data-menu-target="sidebar" class="w-72 glass-card border-r border-slate-200 hidden md:block md:relative md:translate-x-0 fixed inset-y-0 z-40 transform -translate-x-full transition-transform duration-300 ease-in-out">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between md:block">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white font-bold">I</div>
            <span class="font-bold text-xl tracking-tight text-slate-800">Insertrice</span>
          </div>
          <button data-action="menu#toggle" class="p-2 md:hidden">✕</button>
        </div>
        <%= render "shared/sidebar" %>
      </aside>

      <div class="flex-1 flex flex-col min-w-0">
        <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-30">
          <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <button class="md:hidden p-2 text-slate-600 hover:bg-slate-100 rounded-lg" data-action="menu#toggle" aria-label="Open menu">
                <%= lucide_icon :settings, class: "w-6 h-6" %>
              </button>
              <h1 class="text-xl font-bold text-slate-900 tracking-tight"><%= content_for(:page_title) || "Dashboard" %></h1>
            </div>
            <div class="flex items-center gap-4">
              <div class="text-sm font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-full">
                <%= current_user&.email %>
              </div>
            </div>
          </div>
        </header>

        <main class="flex-1 p-8 lg:p-12 max-w-7xl mx-auto w-full">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
  </html>


